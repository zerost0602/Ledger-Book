// --- 공통 아토믹 컴포넌트 ---
const Button = ({ children, variant = 'primary', className = '', ...props }) => {
  const base = "flex items-center justify-center gap-2 px-4 py-2 rounded-xl font-bold transition-all active:scale-95 shadow-sm text-sm";
  const variants = {
    primary: "bg-indigo-600 hover:bg-indigo-700 text-white",
    secondary: "bg-slate-100 hover:bg-slate-200 text-slate-600 border border-slate-200",
    danger: "bg-red-50 hover:bg-red-500 text-red-500 hover:text-white border border-red-100",
    ghost: "bg-transparent hover:bg-slate-100 text-slate-600 shadow-none"
  };
  return <button className={`${base} ${variants[variant]} ${className}`} {...props}>{children}</button>;
};

const Input = ({ className = '', ...props }) => (
  <input className={`w-full p-2.5 rounded-xl border border-slate-200 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition-all text-sm font-bold text-slate-700 bg-white placeholder:text-slate-300 ${className}`} {...props} />
);

const Card = ({ children, className = '' }) => (
  <div className={`bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden ${className}`}>{children}</div>
);

const MoneyText = ({ amount, className = '', colorClass = 'text-slate-800' }) => (
  <span className={`font-mono font-black ${colorClass} ${className}`}>{Number(amount || 0).toLocaleString()}원</span>
);

const Modal = ({ isOpen, onClose, title, children, maxWidth = "max-w-md", zIndex = "z-50" }) => {
  if (!isOpen) return null;
  return (
    <div className={`fixed inset-0 ${zIndex} flex items-end sm:items-center justify-center bg-black/60 backdrop-blur-sm p-0 sm:p-4 animate-in fade-in duration-200`}>
      <div className={`bg-white rounded-t-3xl sm:rounded-3xl w-full ${maxWidth} overflow-hidden shadow-2xl flex flex-col max-h-[92vh] sm:max-h-[95vh]`}>
        <div className="flex justify-between items-center p-4 sm:p-5 border-b bg-slate-50 shrink-0">
          <h3 className="text-sm sm:text-lg font-bold text-slate-800">{title}</h3>
          <button onClick={onClose} className="p-2 hover:bg-slate-200 rounded-full transition-colors text-slate-400">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>
        </div>
        <div className="p-4 sm:p-6 overflow-y-auto modal-scroll bg-white text-slate-800">{children}</div>
      </div>
    </div>
  );
};

// --- Error Boundary ---
class ErrorBoundary extends React.Component {
  constructor(props) {
    super(props);
    this.state = { hasError: false, error: null };
  }
  static getDerivedStateFromError(error) { return { hasError: true, error }; }
  componentDidCatch(error, errorInfo) { console.error("Error caught:", error, errorInfo); }
  render() {
    if (this.state.hasError) {
      return (
        <div className="h-screen flex items-center justify-center bg-slate-50 p-6">
          <Card className="max-w-md text-center p-6">
            <div className="text-red-500 mb-4 flex justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
            </div>
            <h2 className="text-lg font-bold text-slate-800">오류가 발생했습니다</h2>
            <p className="text-sm mt-2 text-slate-500 mb-6">{this.state.error?.toString()}</p>
            <Button onClick={() => window.location.reload()} className="mx-auto">새로고침</Button>
          </Card>
        </div>
      );
    }
    return this.props.children;
  }
}

// --- Custom Hooks ---
const useAccounting = () => {
  const [data, setData] = useState({
    initialSetup: { debits: [], credits: [] },
    accounts: { assets: [], liabilities: [], revenue: [], expenses: [] },
    transactions: []
  });
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState(null);

  const flatAccounts = useMemo(() => [
    ...data.accounts.assets, ...data.accounts.liabilities, ...data.accounts.revenue, ...data.accounts.expenses
  ], [data.accounts]);

  const normalizeData = (rawData) => {
    const sortByName = (arr) => [...arr].sort((a, b) => a.name.localeCompare(b.name, 'ko-KR'));
    const accs = {
      assets: sortByName(rawData.accounts?.assets || []),
      liabilities: sortByName(rawData.accounts?.liabilities || []),
      revenue: sortByName(rawData.accounts?.revenue || []),
      expenses: sortByName(rawData.accounts?.expenses || [])
    };
    const allAccs = [...accs.assets, ...accs.liabilities, ...accs.revenue, ...accs.expenses];
    
    const resolveId = (item) => {
      if (item.accountId) return item.accountId;
      if (item.account === '결산(임시)') return 'closing_temp';
      const found = allAccs.find(a => a.name === item.account);
      return found ? found.id : String(item.account);
    };

    return {
      initialSetup: {
        debits: (rawData.initialSetup?.debits || []).map(d => ({ accountId: resolveId(d), amount: d.amount })),
        credits: (rawData.initialSetup?.credits || []).map(c => ({ accountId: resolveId(c), amount: c.amount }))
      },
      accounts: accs,
      transactions: (rawData.transactions || []).map(tx => ({
        ...tx,
        debits: tx.debits.map(d => ({ accountId: resolveId(d), amount: d.amount })),
        credits: tx.credits.map(c => ({ accountId: resolveId(c), amount: c.amount }))
      }))
    };
  };

  const loadData = useCallback(async (retryCount = 0) => {
    setLoading(true); setError(null);
    try {
      if (typeof google !== 'undefined') {
        const res = await new Promise((resolve, reject) => {
          google.script.run.withSuccessHandler(resolve).withFailureHandler(reject).getAllData();
        });
        setData(normalizeData(res));
      } else {
        setTimeout(() => setLoading(false), 500);
      }
    } catch (e) {
      if (retryCount < 2) setTimeout(() => loadData(retryCount + 1), 1000);
      else setError('데이터 로딩 실패');
    } finally {
      if(typeof google !== 'undefined') setLoading(false);
    }
  }, []);

  useEffect(() => { loadData(); }, [loadData]);

  const getAccountById = useCallback((id) => {
    if (id === 'closing_temp') return { id: 'closing_temp', name: '결산(임시)' };
    const found = flatAccounts.find(a => String(a.id) === String(id));
    return found || { id, name: id }; 
  }, [flatAccounts]);

  const runGasCommand = (cmd, ...args) => {
    return new Promise((resolve, reject) => {
      if (typeof google === 'undefined') { resolve({success: true}); return; }
      google.script.run.withSuccessHandler(res => {
        if(res) resolve(res); else reject("명령 실패");
      }).withFailureHandler(reject)[cmd](...args);
    });
  };

  const saveTransaction = async (tx) => {
    setData(prev => {
      const idx = prev.transactions.findIndex(t => t.id === tx.id);
      const newTxs = [...prev.transactions];
      if (idx >= 0) newTxs[idx] = tx; else newTxs.push(tx);
      return { ...prev, transactions: newTxs };
    });
    try { await runGasCommand('saveTransaction', tx); } 
    catch (e) { alert('거래 저장 실패: ' + e); loadData(); }
  };

  const deleteTransaction = async (id) => {
    setData(prev => ({ ...prev, transactions: prev.transactions.filter(t => t.id !== id) }));
    try { await runGasCommand('deleteTransaction', id); } 
    catch (e) { alert('거래 삭제 실패: ' + e); loadData(); }
  };

  const saveSettingsData = async (newInitialSetup, newAccounts) => {
    setData(prev => ({ ...prev, initialSetup: newInitialSetup, accounts: newAccounts }));
    try { await runGasCommand('saveSettings', { initialSetup: newInitialSetup, accounts: newAccounts }); } 
    catch (e) { alert('설정 저장 실패: ' + e); loadData(); }
  };

  return { data, setData, loading, error, getAccountById, saveTransaction, deleteTransaction, saveSettingsData, flatAccounts, reload: loadData };
};

// --- 컴포넌트 ---
const AccountGridPicker = ({ accounts, onPick }) => {
  const categories = [
    { key: 'assets', label: '자산', color: 'bg-blue-50 text-blue-700 border-blue-200 hover:bg-blue-100' },
    { key: 'liabilities', label: '부채', color: 'bg-red-50 text-red-700 border-red-200 hover:bg-red-100' },
    { key: 'revenue', label: '수익', color: 'bg-emerald-50 text-emerald-700 border-emerald-200 hover:bg-emerald-100' },
    { key: 'expenses', label: '비용', color: 'bg-orange-50 text-orange-700 border-orange-200 hover:bg-orange-100' }
  ];
  return (
    <div className="space-y-6 animate-in slide-in-from-bottom-2 duration-300 pb-10">
      {categories.map(cat => (
        <div key={cat.key}>
          <h4 className="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-3 ml-1">{cat.label}</h4>
          <div className="grid grid-cols-2 sm:grid-cols-4 gap-2">
            {(accounts[cat.key] || []).filter(a => a.name !== '이익잉여금').map(a => (
              <button key={a.id} onClick={() => onPick(a.id)} className={`p-3 rounded-xl border text-xs font-bold transition-all active:scale-95 hover:shadow-md ${cat.color}`}>{a.name}</button>
            ))}
            {cat.key === 'liabilities' && (
              <button onClick={() => onPick('closing_temp')} className="p-3 rounded-xl border text-xs font-bold bg-slate-50 text-slate-400 border-slate-200 hover:bg-slate-100 transition-colors">결산(임시)</button>
            )}
          </div>
