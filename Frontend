                </div>
                <div className="space-y-2">
                  {transactions.filter(t => t.date >= editRange.start && t.date <= editRange.end).sort((a,b) => b.date.localeCompare(a.date)).map(t => (
                    <div key={t.id} onClick={()=>{setEditingTransaction(t); setEntryRows({date:t.date, debits:t.debits, credits:t.credits, memo:t.memo}); setIsEntryModalOpen(true);}} className="p-3.5 bg-white border rounded-xl flex justify-between cursor-pointer hover:border-indigo-500 transition-all shadow-sm active:bg-indigo-50">
                      <div><p className="text-[9px] font-black text-slate-400 uppercase">{t.date}</p><p className="font-bold text-xs text-slate-700 mt-0.5">{t.memo || '거래 내역'}</p></div>
                      <div className="text-right flex flex-col justify-center"><div className="font-mono font-black text-slate-700 text-xs sm:text-base">{(t.debits.reduce((s,d)=>s+d.amount, 0)).toLocaleString()}원</div></div>
                    </div>
                  ))}
                </div>
              </div>
            )}
            {isDirty && (
              <div className="mt-6 md:hidden">
                <Button variant="primary" onClick={handleSyncSettings} className="w-full bg-orange-500 hover:bg-orange-600 animate-pulse">설정 변경사항 저장하기</Button>
              </div>
            )}
          </div>
        </div>
      </Modal>

      <Modal isOpen={isEntryModalOpen} onClose={() => {setIsEntryModalOpen(false); setEditingTransaction(null);}} title={editingTransaction?"전표 수정":"전표 입력"} maxWidth="max-w-6xl" zIndex="z-[120]">
        <div className="flex flex-col lg:flex-row gap-4 sm:gap-6 text-slate-800">
          <div className="w-full lg:w-48 shrink-0 bg-slate-50 p-4 rounded-2xl border h-fit shadow-inner">
            <label className="block text-[9px] font-black text-slate-400 uppercase mb-2 text-center lg:text-left">전표 날짜</label>
            <input type="date" className="w-full p-2.5 rounded-xl border text-xs font-bold outline-none mb-3 shadow-sm bg-white text-slate-700" value={entryRows.date} onChange={(e) => setEntryRows({...entryRows, date: e.target.value})} />
            {editingTransaction && (<button onClick={handleDeleteTransactionWrapper} className="w-full p-3 bg-red-50 text-red-500 rounded-xl font-bold text-[11px] hover:bg-red-500 hover:text-white transition-all shadow-sm flex items-center justify-center gap-2"><i data-lucide="trash-2" className="w-3.5 h-3.5"></i>삭제하기</button>)}
          </div>
          <div className="flex-1 space-y-4 pb-20 sm:pb-0">
            <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div className="bg-white rounded-2xl border shadow-sm flex flex-col overflow-hidden">
                <div className="bg-indigo-600 text-white p-2 font-black text-center text-[10px] uppercase">Debit (차변)</div>
                <div className="p-3 space-y-2 min-h-[120px] sm:min-h-[250px] flex-1">
                  {entryRows.debits.map((r, i) => (
                    <div key={i} className="flex gap-1.5 items-center animate-in slide-in-from-left-2">
                      <button onClick={() => setActivePicker({ type: 'debits', index: i })} className="flex-1 p-2.5 rounded-lg bg-slate-50 text-[11px] font-bold border border-slate-100 text-left truncate active:bg-indigo-50">{r.accountId ? getAccountById(r.accountId).name : '계정 선택'}</button>
                      <input type="number" className="w-20 sm:w-28 p-2 rounded-lg bg-white text-right font-black border border-slate-200 text-xs outline-none" placeholder="0" value={r.amount || ''} onChange={(e) => handleUpdateEntryRow('debits', i, 'amount', Number(e.target.value))} />
                      <button onClick={()=>{const n=[...entryRows.debits]; if(n.length>1){n.splice(i,1); setEntryRows(prev => ({...prev, debits:n}));}}} className="text-slate-300 hover:text-red-500 p-1"><TrashIcon/></button>
                    </div>
                  ))}
                  <button onClick={() => setEntryRows(prev => ({...prev, debits: [...prev.debits, {accountId:'', amount:0}]}))} className="w-full p-2 mt-1 text-[10px] font-black text-indigo-500 border border-dashed border-indigo-200 rounded-lg hover:bg-indigo-50">+ 행 추가</button>
                </div>
                <div className="bg-slate-50 p-2.5 flex justify-between font-black border-t text-xs sm:text-base"><span className="text-[9px] uppercase text-slate-400">Total Debit</span><span className="font-mono text-indigo-600 font-black">{totalDebitSum.toLocaleString()}원</span></div>
              </div>
              <div className="bg-white rounded-2xl border shadow-sm flex flex-col overflow-hidden">
                <div className="bg-red-500 text-white p-2 font-black text-center text-[10px] uppercase">Credit (대변)</div>
                <div className="p-3 space-y-2 min-h-[120px] sm:min-h-[250px] flex-1">
                  {entryRows.credits.map((r, i) => (
                    <div key={i} className="flex gap-1.5 items-center animate-in slide-in-from-right-2">
                      <button onClick={() => setActivePicker({ type: 'credits', index: i })} className="flex-1 p-2.5 rounded-lg bg-slate-50 text-[11px] font-bold border border-slate-100 text-left truncate active:bg-red-50">{r.accountId ? getAccountById(r.accountId).name : '계정 선택'}</button>
                      <input type="number" className="w-20 sm:w-28 p-2 rounded-lg bg-white text-right font-black border border-slate-200 text-xs outline-none" placeholder="0" value={r.amount || ''} onChange={(e) => handleUpdateEntryRow('credits', i, 'amount', Number(e.target.value))} />
                      <button onClick={()=>{const n=[...entryRows.credits]; if(n.length>1){n.splice(i,1); setEntryRows(prev => ({...prev, credits:n}));}}} className="text-slate-300 hover:text-red-500 p-1"><TrashIcon/></button>
                    </div>
                  ))}
                  <button onClick={() => setEntryRows(prev => ({...prev, credits: [...prev.credits, {accountId:'', amount:0}]}))} className="w-full p-2 mt-1 text-[10px] font-black text-red-500 border border-dashed border-red-200 rounded-lg hover:bg-red-50">+ 행 추가</button>
                </div>
                <div className="bg-slate-50 p-2.5 flex justify-between font-black border-t text-xs sm:text-base"><span className="text-[9px] uppercase text-slate-400">Total Credit</span><span className="font-mono text-red-500 font-black">{totalCreditSum.toLocaleString()}원</span></div>
              </div>
            </div>
            <div className="bg-slate-50 p-3 sm:p-4 rounded-2xl border flex flex-col gap-3 shadow-inner">
              <input type="text" className="w-full bg-white p-2.5 rounded-xl border border-slate-200 outline-none font-bold placeholder:text-slate-300 text-slate-700 text-xs sm:text-base" placeholder="거래 메모를 입력하세요 (예: 식비 결제)" value={entryRows.memo} onChange={(e) => setEntryRows({...entryRows, memo: e.target.value})} />
              <div className="flex items-center justify-between gap-4">
                <span className={`px-4 py-2 rounded-full text-[10px] font-black uppercase shadow-sm ${totalDebitSum === totalCreditSum && totalDebitSum > 0 ? 'bg-emerald-500 text-white' : 'bg-slate-200 text-slate-500'}`}>{totalDebitSum === totalCreditSum && totalDebitSum > 0 ? '차대일치' : '불일치'}</span>
                <button onClick={handleSaveEntry} disabled={isSavingEntry || totalDebitSum !== totalCreditSum || totalDebitSum === 0} className="flex-1 bg-indigo-600 hover:bg-indigo-700 disabled:bg-slate-300 text-white px-6 py-3 rounded-xl font-black shadow-lg transition-all active:scale-95 text-xs sm:text-sm whitespace-nowrap">
                  {isSavingEntry ? (
                    <span className="flex items-center justify-center gap-2">
                      <i data-lucide="loader-2" className="w-4 h-4 animate-spin"></i> 저장 중...
                    </span>
                  ) : "전표 저장하기"}
                </button>
              </div>
            </div>
          </div>
        </div>
      </Modal>

      <Modal isOpen={activePicker !== null} onClose={() => setActivePicker(null)} title="계정과목 선택" maxWidth="max-w-4xl" zIndex="z-[150]">
        <AccountGridPicker accounts={accounts} onPick={handleAccountPick} />
      </Modal>
    </div>
  );
};

const Root = () => (
  <ErrorBoundary>
    <App />
  </ErrorBoundary>
);

const root = ReactDOM.createRoot(document.getElementById('root'));
root.render(<Root />);
</script>
</body>
</html>
