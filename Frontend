const MonthlyExpenseReport = ({ accounts, transactions, getAccountById, onEditTransaction }) => {
  const [targetMonth, setTargetMonth] = useState(new Date().toISOString().slice(0, 7));
  const [expandedAccounts, setExpandedAccounts] = useState({});

  const expenseAccountIds = useMemo(() => accounts?.expenses?.map(e => e.id) || [], [accounts]);

  const reportData = useMemo(() => {
    const monthlyTx = transactions.filter(t => {
      const isClosingTx = (t.id && String(t.id).startsWith('CLOSE-')) || (t.memo && t.memo.includes('[결산'));
      return t.date.startsWith(targetMonth) && !isClosingTx;
    });
    
    let map = {};
    let totalExp = 0;

    expenseAccountIds.forEach(accId => { map[accId] = { total: 0, lines: [] }; });

    monthlyTx.forEach(tx => {
      (tx.debits || []).forEach(d => {
        if (expenseAccountIds.includes(d.accountId)) {
          if (!map[d.accountId]) map[d.accountId] = { total: 0, lines: [] };
          map[d.accountId].lines.push({ txId: tx.id, date: tx.date, memo: tx.memo, amount: d.amount });
          map[d.accountId].total += d.amount;
          totalExp += d.amount;
        }
      });
      (tx.credits || []).forEach(c => {
        if (expenseAccountIds.includes(c.accountId)) {
          if (!map[c.accountId]) map[c.accountId] = { total: 0, lines: [] };
          map[c.accountId].lines.push({ txId: tx.id, date: tx.date, memo: tx.memo, amount: -c.amount });
          map[c.accountId].total -= c.amount;
          totalExp -= c.amount;
        }
      });
    });

    const activeAccountIds = Object.keys(map)
      .filter(accId => map[accId].lines.length > 0)
      .sort((a, b) => map[b].total - map[a].total);

    activeAccountIds.forEach(accId => {
      map[accId].lines.sort((a, b) => a.date.localeCompare(b.date));
    });

    return { map, activeAccountIds, totalExp };
  }, [transactions, targetMonth, expenseAccountIds]);

  const toggleAccordion = (accountId) => {
    setExpandedAccounts(prev => ({ ...prev, [accountId]: !prev[accountId] }));
  };

  return (
    <div className="max-w-4xl mx-auto space-y-6 animate-in fade-in duration-300 pb-10">
      <div className="bg-white p-4 sm:p-5 rounded-2xl shadow-sm border border-slate-200 flex items-center justify-between">
        <h2 className="text-lg sm:text-xl font-black text-slate-800 flex items-center gap-2">
          <i data-lucide="receipt" className="text-orange-500"></i> 월간지출명세
        </h2>
        <div className="flex items-center gap-2 bg-slate-50 px-3 py-1.5 rounded-xl border border-slate-200">
          <i data-lucide="calendar" className="w-4 h-4 text-slate-400"></i>
          <input type="month" value={targetMonth} onChange={(e) => setTargetMonth(e.target.value)} className="bg-transparent font-bold text-slate-700 border-none outline-none text-sm cursor-pointer" />
        </div>
      </div>

      <div className="bg-white p-5 rounded-2xl shadow-sm border border-slate-200 space-y-4">
        <div className="flex justify-between items-center mb-4 border-b-2 border-orange-500 pb-2">
          <h3 className="text-sm sm:text-base font-bold text-slate-700 uppercase tracking-widest">비용 계정과목별 상세내역</h3>
          <div className="text-right">
            <span className="text-[10px] font-black text-slate-400 uppercase mr-2">총 지출액</span>
            <span className="font-mono font-black text-orange-600 text-lg sm:text-xl">{reportData.totalExp.toLocaleString()}원</span>
          </div>
        </div>

        {reportData.activeAccountIds.length === 0 && (
          <p className="text-slate-400 text-sm text-center py-8 bg-slate-50 rounded-xl border border-dashed border-slate-200">
            해당 월에 발생한 지출 내역이 없습니다.
          </p>
        )}

        <div className="space-y-3">
          {reportData.activeAccountIds.map(accountId => {
            const isExpanded = !!expandedAccounts[accountId];
            const data = reportData.map[accountId];
            const accountName = getAccountById(accountId).name;

            return (
              <div key={accountId} className="border border-slate-200 rounded-xl overflow-hidden transition-all shadow-sm">
                <div onClick={() => toggleAccordion(accountId)} className="flex justify-between items-center p-3 sm:p-4 bg-slate-50 hover:bg-slate-100 cursor-pointer transition select-none">
                  <div className="font-extrabold text-slate-800 text-sm sm:text-base flex items-center gap-2">
                    <span className="bg-orange-100 text-orange-600 px-2 py-0.5 rounded-md text-[10px] font-black">비용</span>
                    {accountName}
                  </div>
                  <div className="flex items-center gap-4 text-sm">
                    <span className="font-mono font-black text-slate-800">{data.total.toLocaleString()}원</span>
                    <div className="w-6 flex justify-end text-slate-400">
                      {isExpanded ? <i data-lucide="chevron-up" className="w-4 h-4"></i> : <i data-lucide="chevron-down" className="w-4 h-4"></i>}
                    </div>
                  </div>
                </div>

                {isExpanded && (
                  <div className="border-t border-slate-200 bg-white animate-in slide-in-from-top-2 duration-200">
                    <div className="p-3">
                      <table className="w-full text-left text-xs sm:text-sm">
                        <thead className="text-slate-400 text-[10px] font-black uppercase tracking-widest border-b border-slate-100 bg-slate-50">
                          <tr>
                            <th className="py-2 px-3 rounded-tl-lg w-32 whitespace-nowrap">날짜</th>
                            <th className="py-2 px-3">거래내용</th>
                            <th className="py-2 px-3 text-right rounded-tr-lg w-28">금액</th>
                          </tr>
                        </thead>
                        <tbody className="divide-y divide-slate-50">
                          {data.lines.map((line, idx) => (
                            <tr key={idx} onClick={() => line.txId && onEditTransaction && onEditTransaction(line.txId)} className={`transition ${line.txId && onEditTransaction ? 'cursor-pointer hover:bg-indigo-50 active:bg-indigo-100' : 'hover:bg-slate-50'}`}>
                              <td className="py-2.5 px-3 text-slate-500 font-mono whitespace-nowrap">{line.date}</td>
                              <td className="py-2.5 px-3 text-slate-700 font-bold">{line.memo || '내역 없음'}</td>
                              <td className="py-2.5 px-3 text-right font-mono font-bold text-slate-800">{line.amount.toLocaleString()}원</td>
                            </tr>
                          ))}
                        </tbody>
                      </table>
                    </div>
                  </div>
                )}
              </div>
            );
          })}
        </div>
      </div>
    </div>
  );
};

const MonthlyCalendar = ({ accounts, transactions, getAccountById, onEditTransaction }) => {
  const [currentDate, setCurrentDate] = useState(new Date());
  const [selectedDate, setSelectedDate] = useState(null);

  const year = currentDate.getFullYear();
  const month = currentDate.getMonth();
  const firstDayOfMonth = new Date(year, month, 1).getDay();
  const daysInMonth = new Date(year, month + 1, 0).getDate();

  const revenueAccountIds = useMemo(() => (accounts?.revenue || []).map(a => a.id), [accounts]);
  const expenseAccountIds = useMemo(() => (accounts?.expenses || []).map(a => a.id), [accounts]);

  const dailyData = useMemo(() => {
    const data = {};
    (transactions || []).forEach(tx => {
      const isClosingTx = (tx.id && String(tx.id).startsWith('CLOSE-')) || (tx.memo && tx.memo.includes('[결산'));
      if (isClosingTx) return;

      if (!data[tx.date]) data[tx.date] = { revenue: 0, expense: 0, txs: [] };
      data[tx.date].txs.push(tx);

      (tx.credits || []).forEach(c => { if (revenueAccountIds.includes(c.accountId)) data[tx.date].revenue += c.amount; });
      (tx.debits || []).forEach(d => {
        if (revenueAccountIds.includes(d.accountId)) data[tx.date].revenue -= d.amount;
        if (expenseAccountIds.includes(d.accountId)) data[tx.date].expense += d.amount;
      });
      (tx.credits || []).forEach(c => {
        if (expenseAccountIds.includes(c.accountId)) data[tx.date].expense -= c.amount;
      });
    });
    return data;
  }, [transactions, revenueAccountIds, expenseAccountIds]);

  const days = [];
  for (let i = 0; i < firstDayOfMonth; i++) days.push(null);
  for (let i = 1; i <= daysInMonth; i++) days.push(i);

  const handlePrevMonth = () => setCurrentDate(new Date(year, month - 1, 1));
  const handleNextMonth = () => setCurrentDate(new Date(year, month + 1, 1));

  useEffect(() => {
    setTimeout(() => { if (window.lucide) window.lucide.createIcons(); }, 100);
  }, [currentDate, selectedDate]);

  return (
    <div className="max-w-6xl mx-auto space-y-4 sm:space-y-6 animate-in fade-in duration-300 pb-10">
      <div className="bg-white p-4 sm:p-5 rounded-2xl shadow-sm border border-slate-200 flex items-center justify-between">
        <h2 className="text-lg sm:text-xl font-black text-slate-800 flex items-center gap-2">
          <i data-lucide="calendar-days" className="text-indigo-500"></i> 월간 캘린더
        </h2>
        <div className="flex items-center gap-4">
          <button onClick={handlePrevMonth} className="p-2 hover:bg-slate-100 rounded-full transition-colors text-slate-500"><i data-lucide="chevron-left" className="w-5 h-5"></i></button>
          <span className="font-black text-slate-700 w-24 text-center">{year}년 {month + 1}월</span>
          <button onClick={handleNextMonth} className="p-2 hover:bg-slate-100 rounded-full transition-colors text-slate-500"><i data-lucide="chevron-right" className="w-5 h-5"></i></button>
        </div>
      </div>

      <div className="bg-white p-3 sm:p-5 rounded-2xl shadow-sm border border-slate-200">
        <div className="grid grid-cols-7 gap-1 sm:gap-2 mb-2">
          {['일', '월', '화', '수', '목', '금', '토'].map((d, i) => (
            <div key={d} className={`text-center font-bold text-xs sm:text-sm py-2 ${i === 0 ? 'text-red-400' : i === 6 ? 'text-blue-400' : 'text-slate-400'}`}>{d}</div>
          ))}
        </div>
        <div className="grid grid-cols-7 gap-1 sm:gap-2">
          {days.map((d, i) => {
            if (!d) return <div key={i} className="bg-slate-50/50 rounded-xl min-h-[80px] sm:min-h-[120px]"></div>;
            const dateStr = `${year}-${String(month + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
            const info = dailyData[dateStr] || { revenue: 0, expense: 0, txs: [] };
            
            return (
              <div key={i} onClick={() => info.txs.length > 0 && setSelectedDate(dateStr)} className={`min-h-[80px] sm:min-h-[120px] p-1 sm:p-2 rounded-xl border transition-all flex flex-col ${info.txs.length > 0 ? 'cursor-pointer hover:border-indigo-400 hover:shadow-md bg-white border-slate-200' : 'bg-white border-slate-100'}`}>
                <span className={`font-bold text-xs sm:text-sm mb-1 sm:mb-2 ml-1 ${i % 7 === 0 ? 'text-red-400' : i % 7 === 6 ? 'text-blue-400' : 'text-slate-600'}`}>{d}</span>
                <div className="flex-1 space-y-1 mt-auto flex flex-col justify-end">
                  {info.revenue > 0 && <div className="text-[9px] sm:text-xs font-mono font-black text-emerald-600 bg-emerald-50 px-0.5 sm:px-1 py-0.5 rounded text-right tracking-tighter break-all sm:truncate leading-[1.1] sm:leading-normal">+{info.revenue.toLocaleString()}</div>}
                  {info.expense > 0 && <div className="text-[9px] sm:text-xs font-mono font-black text-red-500 bg-red-50 px-0.5 sm:px-1 py-0.5 rounded text-right tracking-tighter break-all sm:truncate leading-[1.1] sm:leading-normal">-{info.expense.toLocaleString()}</div>}
                </div>
              </div>
            );
          })}
        </div>
      </div>

      <Modal isOpen={!!selectedDate} onClose={() => setSelectedDate(null)} title={`${selectedDate} 상세 내역`}>
        <div className="space-y-3 modal-scroll max-h-[60vh] overflow-y-auto pr-2">
          {selectedDate && dailyData[selectedDate] && dailyData[selectedDate].txs.map(tx => (
            <div key={tx.id} onClick={() => { onEditTransaction(tx.id); setSelectedDate(null); }} className="p-3 border border-slate-100 bg-slate-50 rounded-xl hover:bg-indigo-50 hover:border-indigo-200 transition-all cursor-pointer shadow-sm">
              <div className="font-bold text-slate-700 mb-2">{tx.memo || '내역 없음'}</div>
              <div className="grid grid-cols-2 gap-3 text-[11px] sm:text-xs bg-white p-2 rounded-lg border border-slate-100">
                <div>
                  <div className="text-[9px] text-slate-400 uppercase font-black mb-1">차변 (Debit)</div>
                  {tx.debits.map((d, idx) => <div key={idx} className="flex justify-between items-center py-0.5"><span className="text-indigo-600 font-medium truncate pr-1">{getAccountById(d.accountId)?.name}</span><MoneyText amount={d.amount} className="text-[10px] sm:text-xs" /></div>)}
                </div>
                <div>
                  <div className="text-[9px] text-slate-400 uppercase font-black mb-1">대변 (Credit)</div>
                  {tx.credits.map((c, idx) => <div key={idx} className="flex justify-between items-center py-0.5"><span className="text-red-500 font-medium truncate pr-1">{getAccountById(c.accountId)?.name}</span><MoneyText amount={c.amount} className="text-[10px] sm:text-xs" /></div>)}
                </div>
              </div>
            </div>
          ))}
        </div>
      </Modal>
    </div>
  );
};

// --- App Component ---
const App = () => {
  const { data, setData, loading, error, getAccountById, saveTransaction, deleteTransaction, saveSettingsData, flatAccounts, reload } = useAccounting();
  
  const [isDirty, setIsDirty] = useState(false);
  const [currentView, setCurrentView] = useState('CALENDAR');
  const [isSidebarOpen, setIsSidebarOpen] = useState(window.innerWidth > 1024);
  const [isSettingsModalOpen, setIsSettingsModalOpen] = useState(false);
  const [settingsTab, setSettingsTab] = useState('equity');
  const [isEntryModalOpen, setIsEntryModalOpen] = useState(false);
  const [editingTransaction, setEditingTransaction] = useState(null);

  const [statusMessage, setStatusMessage] = useState(null);
  const [confirmDialog, setConfirmDialog] = useState(null);
  const [activePicker, setActivePicker] = useState(null);

  const [standardDate, setStandardDate] = useState(new Date().toISOString().split('T')[0]);
  const [editRange, setEditRange] = useState({
    start: new Date(new Date().getFullYear(), new Date().getMonth(), 1).toISOString().split('T')[0],
    end: new Date().toISOString().split('T')[0]
  });

  const [entryRows, setEntryRows] = useState({
    date: new Date().toISOString().split('T')[0],
    debits: [{ accountId: '', amount: 0 }],
    credits: [{ accountId: '', amount: 0 }],
    memo: ''
  });

  const [addingToCategory, setAddingToCategory] = useState(null);
  const [draggedAccountId, setDraggedAccountId] = useState(null);
  const [searchTerm, setSearchTerm] = useState('');
  const [searchDateRange, setSearchDateRange] = useState({ start: '', end: '' });
  const [isSavingEntry, setIsSavingEntry] = useState(false);

  useEffect(() => { if (statusMessage) { const t = setTimeout(() => setStatusMessage(null), 3000); return () => clearTimeout(t); } }, [statusMessage]);
  useEffect(() => { setTimeout(() => lucide.createIcons(), 50); });

  const initialSetup = data.initialSetup;
  const accounts = data.accounts;
  const transactions = data.transactions;

  const setupTotalDebits = useMemo(() => (initialSetup.debits || []).reduce((s, d) => s + Number(d.amount || 0), 0), [initialSetup.debits]);
  const setupTotalOtherCredits = useMemo(() => (initialSetup.credits || []).reduce((s, c) => s + Number(c.amount || 0), 0), [initialSetup.credits]);
  const calculatedInitialCapital = useMemo(() => setupTotalDebits - setupTotalOtherCredits, [setupTotalDebits, setupTotalOtherCredits]);

  const yearStartDate = useMemo(() => `${standardDate.split('-')[0]}-01-01`, [standardDate]);
  const allBsTransactions = useMemo(() => transactions.filter(t => t.date <= standardDate), [transactions, standardDate]);
  const performanceTransactions = useMemo(() => transactions.filter(t => t.date >= yearStartDate && t.date <= standardDate), [transactions, yearStartDate, standardDate]);

  const accountBalances = useMemo(() => {
    const balances = {};
    flatAccounts.forEach(a => balances[a.id] = 0);
    balances['closing_temp'] = 0;
    (initialSetup.debits || []).forEach(d => { if (d.accountId) { balances[d.accountId] = (balances[d.accountId] || 0) + Number(d.amount || 0); } });
    (initialSetup.credits || []).forEach(c => { if (c.accountId) { balances[c.accountId] = (balances[c.accountId] || 0) - Number(c.amount || 0); } });
    allBsTransactions.forEach(t => {
      t.debits.forEach(d => { balances[d.accountId] = (balances[d.accountId] || 0) + Number(d.amount || 0); });
      t.credits.forEach(c => { balances[c.accountId] = (balances[c.accountId] || 0) - Number(c.amount || 0); });
    });
    return balances;
  }, [allBsTransactions, accounts, initialSetup, flatAccounts]);

  const revenueHierarchy = useMemo(() => {
    const subtypes = ['fixed', 'variable'];
    const groups = subtypes.map(st => {
      const accs = accounts.revenue.filter(a => (a.subtype || 'fixed') === st).map(acc => {
        let amt = 0;
        performanceTransactions.forEach(t => { t.credits.forEach(c => { if(c.accountId === acc.id) amt += Number(c.amount); }); t.debits.forEach(d => { if(d.accountId === acc.id) amt -= Number(d.amount); }); });
        return { name: acc.name, amount: amt };
      }).filter(a => a.amount !== 0);
      return { label: st === 'fixed' ? '고정 항목' : '변동 항목', subtotal: accs.reduce((s, a) => s + a.amount, 0), accounts: accs };
    });
    return { total: groups.reduce((s, g) => s + g.subtotal, 0), groups };
  }, [performanceTransactions, accounts]);

  const expensesHierarchy = useMemo(() => {
    const subtypes = ['fixed', 'variable'];
    const groups = subtypes.map(st => {
      const accs = accounts.expenses.filter(a => (a.subtype || 'fixed') === st).map(acc => {
        let amt = 0;
        performanceTransactions.forEach(t => { t.debits.forEach(d => { if(d.accountId === acc.id) amt += Number(d.amount); }); t.credits.forEach(c => { if(c.accountId === acc.id) amt -= Number(c.amount); }); });
        return { name: acc.name, amount: amt };
      }).filter(a => a.amount !== 0);
      return { label: st === 'fixed' ? '고정 항목' : '변동 항목', subtotal: accs.reduce((s, a) => s + a.amount, 0), accounts: accs };
    });
    return { total: groups.reduce((s, g) => s + g.subtotal, 0), groups };
  }, [performanceTransactions, accounts]);

  const reportNetIncome = useMemo(() => revenueHierarchy.total - expensesHierarchy.total, [revenueHierarchy, expensesHierarchy]);

  const unsettledNetIncome = useMemo(() => {
    const revBal = accounts.revenue.reduce((sum, acc) => {
        const bal = accountBalances[acc.id] || 0;
        return sum + (bal < 0 ? Math.abs(bal) : -bal);
    }, 0);
    const expBal = accounts.expenses.reduce((sum, acc) => {
        const bal = accountBalances[acc.id] || 0;
        return sum + (bal > 0 ? bal : -Math.abs(bal));
    }, 0);
    return revBal - expBal;
  }, [accountBalances, accounts]);

  const totalAssets = accounts.assets.reduce((sum, acc) => sum + (accountBalances[acc.id] || 0), 0);
  const totalLiabilitiesOnly = accounts.liabilities.filter(a => a.name !== '이익잉여금').reduce((sum, acc) => sum + Math.abs(accountBalances[acc.id] || 0), 0);
  
  const retainedEarningsAcc = flatAccounts.find(a => a.name === '이익잉여금');
  const retainedEarningsId = retainedEarningsAcc ? retainedEarningsAcc.id : 'e1';
  const retainedEarningsBalance = Math.abs(accountBalances[retainedEarningsId] || 0);
  const currentEquity = calculatedInitialCapital + (accountBalances[retainedEarningsId] < 0 ? Math.abs(accountBalances[retainedEarningsId]) : -accountBalances[retainedEarningsId]) + unsettledNetIncome;

  const totalDebitSum = useMemo(() => (entryRows.debits || []).reduce((s, r) => s + Number(r.amount || 0), 0), [entryRows.debits]);
  const totalCreditSum = useMemo(() => (entryRows.credits || []).reduce((s, r) => s + Number(r.amount || 0), 0), [entryRows.credits]);

  const handleSyncSettings = async () => {
    await saveSettingsData(initialSetup, accounts);
    setIsDirty(false); setStatusMessage({ type: 'success', text: '설정 저장 완료' });
  };

  const handleAddAccount = (category, name) => {
    if (!name.trim()) return;
    setData(prev => {
      const newArr = [...prev.accounts[category], { id: Date.now().toString(), name: name.trim(), subtype: 'fixed' }];
      newArr.sort((a, b) => a.name.localeCompare(b.name, 'ko-KR'));
      return { ...prev, accounts: { ...prev.accounts, [category]: newArr } };
    });
    setIsDirty(true); setAddingToCategory(null);
  };

  const handleUpdateAccountName = (category, id, name) => {
    setData(prev => {
      const newArr = prev.accounts[category].map(a => String(a.id) === String(id) ? { ...a, name: name.trim() } : a);
      newArr.sort((a, b) => a.name.localeCompare(b.name, 'ko-KR'));
      return { ...prev, accounts: { ...prev.accounts, [category]: newArr } };
    });
    setIsDirty(true);
  };

  const handleDeleteAccount = (category, id) => {
    setConfirmDialog({
      title: '삭제 확인', message: '해당 계정과목을 삭제하시겠습니까?',
      onConfirm: () => {
        setData(prev => ({ ...prev, accounts: { ...prev.accounts, [category]: prev.accounts[category].filter(a => String(a.id) !== String(id)) } }));
        setIsDirty(true); setConfirmDialog(null);
      }
    });
  };

  const handleDeleteTransactionWrapper = () => {
    if (!editingTransaction) return;
    setConfirmDialog({
      title: '전표 삭제', message: '이 거래를 삭제하시겠습니까?',
      onConfirm: async () => {
        await deleteTransaction(editingTransaction.id);
        setIsEntryModalOpen(false); setEditingTransaction(null); setConfirmDialog(null);
      }
    });
  };

  const handleSaveEntry = async () => {
    if (totalDebitSum !== totalCreditSum || totalDebitSum === 0) return;
    setIsSavingEntry(true);
    try {
      const newTransaction = {
        id: editingTransaction ? editingTransaction.id : `T-${Date.now()}`,
        date: entryRows.date,
        debits: entryRows.debits.filter(d => d.accountId && d.amount > 0),
        credits: entryRows.credits.filter(c => c.accountId && c.amount > 0),
        memo: entryRows.memo || '거래 내역'
      };
      await saveTransaction(newTransaction);
      setIsEntryModalOpen(false); setEditingTransaction(null);
      setEntryRows({ date: new Date().toISOString().split('T')[0], debits: [{ accountId: '', amount: 0 }], credits: [{ accountId: '', amount: 0 }], memo: '' });
    } finally {
      setIsSavingEntry(false);
    }
  };

  const handleClosing = () => {
    const closingDebits = [];
    const closingCredits = [];
    let totalRevToClear = 0;
    let totalExpToClear = 0;

    accounts.revenue.forEach(acc => {
      const bal = accountBalances[acc.id] || 0;
      if (bal !== 0) {
        if (bal < 0) {
          const amt = Math.abs(bal);
          closingDebits.push({ accountId: acc.id, amount: amt });
          totalRevToClear += amt;
        } else {
          const amt = bal;
          closingCredits.push({ accountId: acc.id, amount: amt });
          totalRevToClear -= amt;
        }
      }
    });

    accounts.expenses.forEach(acc => {
      const bal = accountBalances[acc.id] || 0;
      if (bal !== 0) {
        if (bal > 0) {
          const amt = bal;
          closingCredits.push({ accountId: acc.id, amount: amt });
          totalExpToClear += amt;
        } else {
          const amt = Math.abs(bal);
          closingDebits.push({ accountId: acc.id, amount: amt });
          totalExpToClear -= amt;
        }
      }
    });

    if (totalRevToClear === 0 && totalExpToClear === 0) {
      setStatusMessage({ type: 'error', text: '결산할 잔액이 없습니다.' });
      return;
    }

    const netIncome = totalRevToClear - totalExpToClear;

    setConfirmDialog({
      title: '장부 결산 실행',
      message: `${standardDate} 기준으로 수익과 비용의 모든 잔액을 정리하시겠습니까? (순이익 ${netIncome.toLocaleString()}원)`,
      onConfirm: async () => {
        const ts = Date.now();
        const entry1_debits = [...closingDebits];
        const entry1_credits = [...closingCredits];
        if (netIncome > 0) { entry1_credits.push({ accountId: 'closing_temp', amount: netIncome }); } 
        else if (netIncome < 0) { entry1_debits.push({ accountId: 'closing_temp', amount: Math.abs(netIncome) }); }

        const entry1 = { id: `CLOSE-A-${ts}`, date: standardDate, debits: entry1_debits, credits: entry1_credits, memo: `[결산-1] ${standardDate} 수익비용 잔액 집계` };

        const entry2_debits = [];
        const entry2_credits = [];
        if (netIncome > 0) {
          entry2_debits.push({ accountId: 'closing_temp', amount: netIncome });
          entry2_credits.push({ accountId: retainedEarningsId, amount: netIncome });
        } else if (netIncome < 0) {
          const loss = Math.abs(netIncome);
          entry2_debits.push({ accountId: retainedEarningsId, amount: loss });
          entry2_credits.push({ accountId: 'closing_temp', amount: loss });
        }

        await saveTransaction(entry1);
        if (netIncome !== 0) {
          await saveTransaction({ id: `CLOSE-B-${ts}`, date: standardDate, debits: entry2_debits, credits: entry2_credits, memo: `[결산-2] ${standardDate} 순이익 이익잉여금 대체` });
        }
        setConfirmDialog(null); setStatusMessage({ type: 'success', text: '결산이 완료되었습니다.' });
      }
    });
  };

  const handleUpdateEntryRow = (type, index, field, value) => {
    setEntryRows(prev => {
      const newRows = [...prev[type]];
      newRows[index] = { ...newRows[index], [field]: value };
      return { ...prev, [type]: newRows };
    });
  };

  const handleAccountPick = (id) => {
    if (!activePicker) return;
    const { type, index } = activePicker;
    if (type === 'setupDebits') setData(prev => { const n = [...prev.initialSetup.debits]; n[index].accountId = id; return { ...prev, initialSetup: { ...prev.initialSetup, debits: n } }; });
    else if (type === 'setupCredits') setData(prev => { const n = [...prev.initialSetup.credits]; n[index].accountId = id; return { ...prev, initialSetup: { ...prev.initialSetup, credits: n } }; });
    else handleUpdateEntryRow(type, index, 'accountId', id);
    setActivePicker(null); setIsDirty(true);
  };

  const handleDragOver = (e) => e.preventDefault();
  const handleAccountDragStart = (id) => setDraggedAccountId(id);
  const handleSubtypeDrop = (subtype, type) => {
    if (!draggedAccountId) return;
    setData(prev => ({ ...prev, accounts: { ...prev.accounts, [type]: prev.accounts[type].map(a => String(a.id) === String(draggedAccountId) ? { ...a, subtype } : a) } }));
    setIsDirty(true); setDraggedAccountId(null);
  };

  const filteredTxs = useMemo(() => {
    if (!searchTerm && !searchDateRange.start && !searchDateRange.end) return [];
    const term = searchTerm.toLowerCase();
    return transactions.filter(t => {
      if (searchDateRange.start && t.date < searchDateRange.start) return false;
      if (searchDateRange.end && t.date > searchDateRange.end) return false;
      if (!term) return true;
      if (t.memo && t.memo.toLowerCase().includes(term)) return true;
      if (t.date.includes(term)) return true;
      const dMatch = t.debits.some(d => getAccountById(d.accountId)?.name.toLowerCase().includes(term));
      const cMatch = t.credits.some(c => getAccountById(c.accountId)?.name.toLowerCase().includes(term));
      return dMatch || cMatch;
    }).sort((a,b) => b.date.localeCompare(a.date));
  }, [transactions, searchTerm, searchDateRange, getAccountById]);

  if (error) throw new Error(error);

  return (
    <div className="flex flex-col md:flex-row h-screen bg-slate-50 overflow-hidden text-slate-900">
      {loading && <div className="loading-overlay"><div className="w-10 h-10 border-4 border-indigo-600 border-t-transparent rounded-full animate-spin mb-4"></div><p className="font-bold text-indigo-600 text-sm">데이터 동기화 중...</p></div>}
      {statusMessage && <div className="fixed top-4 right-4 z-[300] p-4 rounded-2xl shadow-2xl border bg-emerald-50 border-emerald-200 text-emerald-800 font-bold text-sm">✓ {statusMessage.text}</div>}

      <Modal isOpen={confirmDialog !== null} onClose={() => setConfirmDialog(null)} title={confirmDialog?.title || '확인'} maxWidth="max-w-md" zIndex="z-[200]">
        <div className="space-y-6 text-center">
          <p className="font-medium text-slate-600 leading-relaxed text-sm">{confirmDialog?.message}</p>
          <div className="flex gap-3 justify-center pb-2">
            <Button variant="secondary" onClick={() => setConfirmDialog(null)}>취소</Button>
            <Button onClick={confirmDialog?.onConfirm}>확인</Button>
          </div>
        </div>
      </Modal>

      <aside className={`sidebar-transition bg-white border-r border-slate-200 shrink-0 flex flex-col overflow-hidden fixed md:relative z-40 shadow-xl md:shadow-none h-full ${isSidebarOpen ? 'w-64' : 'w-0 md:w-20'}`}>
        <div className="p-6 flex items-center gap-3">
          <div className="bg-indigo-600 p-2 rounded-xl text-white shadow-lg shrink-0"><i data-lucide="wallet"></i></div>
          {isSidebarOpen && <span className="font-bold text-xl animate-in fade-in">DoubleBook</span>}
        </div>
        <nav className="flex-1 px-3 space-y-1 mt-4">
          {[
            { id: 'CALENDAR', label: '캘린더', icon: 'calendar-days' },
            { id: 'BS', label: '재무상태표', icon: 'layout-dashboard' },
            { id: 'IS', label: '손익계산서', icon: 'pie-chart' },
            { id: 'GL', label: '총계정원장', icon: 'book-open' },
            { id: 'EXPENSE_REPORT', label: '월간지출명세', icon: 'receipt' }
          ].map(nav => (
            <button key={nav.id} onClick={() => { setCurrentView(nav.id); if(window.innerWidth < 768) setIsSidebarOpen(false); }} className={`w-full flex items-center gap-3 p-3 rounded-xl transition-all ${currentView === nav.id ? 'bg-indigo-600 text-white shadow-md' : 'hover:bg-slate-100 text-slate-500'}`}>
              <i data-lucide={nav.icon} className="shrink-0"></i>
              {isSidebarOpen && <span className="font-medium animate-in fade-in whitespace-nowrap">{nav.label}</span>}
            </button>
          ))}
        </nav>
        <div className="p-3 border-t text-slate-800 space-y-2 mb-4">
          <button onClick={() => { setIsSettingsModalOpen(true); if(window.innerWidth < 768) setIsSidebarOpen(false); }} className="w-full flex items-center gap-3 p-3 rounded-xl hover:bg-slate-100 font-bold transition-colors">
            <i data-lucide="settings" className="shrink-0"></i>
            {isSidebarOpen && <span className="animate-in fade-in whitespace-nowrap">설정</span>}
          </button>
        </div>
      </aside>

      {isSidebarOpen && <div onClick={() => setIsSidebarOpen(false)} className="md:hidden fixed inset-0 bg-black/40 z-30 backdrop-blur-sm animate-in fade-in"></div>}

      <main className="flex-1 flex flex-col overflow-hidden relative">
        <header className="h-14 sm:h-16 bg-white border-b flex items-center justify-between px-3 sm:px-6 shrink-0 z-10 shadow-sm text-slate-800">
          <div className="flex items-center gap-3 sm:gap-6">
            <button onClick={() => setIsSidebarOpen(!isSidebarOpen)} className="p-2 hover:bg-slate-100 rounded-lg text-slate-500"><i data-lucide={isSidebarOpen ? 'chevron-left' : 'menu'} className="w-5 h-5"></i></button>
            <div className="flex items-center gap-1 sm:gap-3 bg-slate-50 px-2 sm:px-3 py-1.5 rounded-xl border border-slate-100 text-slate-700 font-bold">
              <i data-lucide="calendar" className="text-indigo-500 w-3 h-3 sm:w-4 sm:h-4"></i>
              <input type="date" className="bg-transparent border-none outline-none text-[11px] sm:text-sm font-bold w-24 sm:w-32 cursor-pointer text-slate-700" value={standardDate} onChange={(e) => setStandardDate(e.target.value)} />
            </div>
          </div>
          <div className="flex items-center gap-2">
            <Button variant="secondary" onClick={handleClosing} className="text-[11px] sm:text-sm px-3 sm:px-5">
              <i data-lucide="calculator" className="w-3.5 h-3.5 sm:w-4 sm:h-4"></i><span>결산 실행</span>
            </Button>
            <Button onClick={() => { setEntryRows({ date: standardDate, debits: [{ accountId: '', amount: 0 }], credits: [{ accountId: '', amount: 0 }], memo: '' }); setIsEntryModalOpen(true); }} className="text-[11px] sm:text-sm px-3 sm:px-5">
              <i data-lucide="plus-circle" className="w-3.5 h-3.5 sm:w-4 sm:h-4"></i><span>거래 입력</span>
            </Button>
          </div>
        </header>

        <div className="flex-1 overflow-y-auto p-3 sm:p-8 pb-24">
          {currentView === 'CALENDAR' && (
            <MonthlyCalendar 
              accounts={accounts} 
              transactions={transactions} 
              getAccountById={getAccountById} 
              onEditTransaction={(txId) => {
                const tx = transactions.find(t => t.id === txId);
                if(tx) { 
                  setEditingTransaction(tx); 
                  setEntryRows({ date: tx.date, debits: tx.debits, credits: tx.credits, memo: tx.memo }); 
                  setIsEntryModalOpen(true); 
                }
              }} 
            />
