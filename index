// --- Error Boundary ---
class ErrorBoundary extends React.Component {
  constructor(props) {
    super(props);
    this.state = { hasError: false, error: null };
  }
  static getDerivedStateFromError(error) { return { hasError: true, error }; }
  componentDidCatch(error, errorInfo) { console.error("Error caught:", error, errorInfo); }
  render() {
    if (this.state.hasError) {
      return html`
        <div className="h-screen flex items-center justify-center bg-slate-50 dark:bg-[#080c16] p-6 theme-transition">
          <${Card} className="max-w-md text-center p-6 border-red-200 dark:border-red-900/30">
            <div className="text-red-500 dark:text-red-400 mb-4 flex justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
            </div>
            <h2 className="text-lg font-black text-slate-800 dark:text-slate-100">오류가 발생했습니다</h2>
            <p className="text-sm mt-2 text-slate-500 dark:text-slate-400 mb-6">${this.state.error?.toString()}</p>
            <${Button} onClick=${() => window.location.reload()} className="mx-auto">새로고침<//>
          <//>
        </div>
      `;
    }
    return this.props.children;
  }
}

// --- Custom Hooks ---
const useAccounting = () => {
  const [data, setData] = useState({
    initialSetup: { debits: [], credits: [] },
    accounts: { assets: [], liabilities: [], revenue: [], expenses: [] },
    transactions: [],
    budgets: {}
  });
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState(null);

  const flatAccounts = useMemo(() => [
    ...data.accounts.assets, ...data.accounts.liabilities, ...data.accounts.revenue, ...data.accounts.expenses
  ], [data.accounts]);

  const normalizeData = (rawData) => {
    const sortByName = (arr) => [...arr].sort((a, b) => a.name.localeCompare(b.name, 'ko-KR'));
    const sanitizeAccs = (arr) => sortByName(arr).map(a => ({ ...a, tags: a.tags || [] }));
    const accs = {
      assets: sanitizeAccs(rawData.accounts?.assets || []),
      liabilities: sanitizeAccs(rawData.accounts?.liabilities || []),
      revenue: sanitizeAccs(rawData.accounts?.revenue || []),
      expenses: sanitizeAccs(rawData.accounts?.expenses || [])
    };
    const allAccs = [...accs.assets, ...accs.liabilities, ...accs.revenue, ...accs.expenses];
    
    const resolveId = (item) => {
      if (item.accountId) return item.accountId;
      if (item.account === '결산(임시)') return 'closing_temp';
      const found = allAccs.find(a => a.name === item.account);
      return found ? found.id : String(item.account);
    };

    return {
      initialSetup: {
        debits: (rawData.initialSetup?.debits || []).map(d => ({ accountId: resolveId(d), amount: d.amount })),
        credits: (rawData.initialSetup?.credits || []).map(c => ({ accountId: resolveId(c), amount: c.amount }))
      },
      accounts: accs,
      transactions: (rawData.transactions || []).map(tx => ({
        ...tx,
        debits: tx.debits.map(d => ({ accountId: resolveId(d), amount: d.amount, tag: d.tag || '' })),
        credits: tx.credits.map(c => ({ accountId: resolveId(c), amount: c.amount, tag: c.tag || '' }))
      })),
      budgets: rawData.budgets || {}
    };
  };

  const loadData = useCallback(async (retryCount = 0) => {
    setLoading(true); setError(null);
    try {
      if (typeof google !== 'undefined') {
        const res = await new Promise((resolve, reject) => {
          google.script.run.withSuccessHandler(resolve).withFailureHandler(reject).getAllData();
        });
        setData(normalizeData(res));
      } else {
        // 로컬 프로토타입 확인을 위한 가상 데이터
        const today = new Date();
        const currentMonth = today.toISOString().slice(0, 7);
        const lastMonthDate = new Date(today.getFullYear(), today.getMonth() - 1, 1);
        const lastMonth = lastMonthDate.toISOString().slice(0, 7);
        
        const mockRes = {
          initialSetup: {
            debits: [{ accountId: 'a1', amount: 5000000 }, { accountId: 'a2', amount: 500000 }],
            credits: [{ accountId: 'e1', amount: 5500000 }]
          },
          accounts: {
            assets: [
              { id: 'a1', name: '보통예금', subtype: 'fixed', tags: ['이체', '저축'] },
              { id: 'a2', name: '현금', subtype: 'fixed', tags: ['비상금'] }
            ],
            liabilities: [
              { id: 'l1', name: '신용카드', subtype: 'variable', tags: ['일시불', '할부'] },
              { id: 'e1', name: '이익잉여금', subtype: 'fixed', tags: [] }
            ],
            revenue: [
              { id: 'r1', name: '급여', subtype: 'fixed', tags: ['기본급', '상여금'] },
              { id: 'r2', name: '이자수익', subtype: 'variable', tags: [] }
            ],
            expenses: [
              { id: 'x1', name: '식비', subtype: 'variable', tags: ['외식', '식재료', '배달'] },
              { id: 'x2', name: '교통비', subtype: 'variable', tags: ['지하철', '버스', '택시'] },
              { id: 'x3', name: '주거비', subtype: 'fixed', tags: ['월세', '관리비'] },
              { id: 'x4', name: '통신비', subtype: 'fixed', tags: ['휴대폰', '인터넷'] }
            ]
          },
          transactions: [
            {
              id: 'tx-1',
              date: `${currentMonth}-01`,
              debits: [{ accountId: 'x3', amount: 500000, tag: '월세' }],
              credits: [{ accountId: 'a1', amount: 500000, tag: '이체' }],
              memo: '월세 납부'
            },
            {
              id: 'tx-2',
              date: `${currentMonth}-02`,
              debits: [{ accountId: 'x1', amount: 12000, tag: '외식' }],
              credits: [{ accountId: 'l1', amount: 12000, tag: '일시불' }],
              memo: '점심 식사'
            },
            {
              id: 'tx-3',
              date: `${currentMonth}-03`,
              debits: [{ accountId: 'x1', amount: 45000, tag: '식재료' }],
              credits: [{ accountId: 'l1', amount: 45000, tag: '일시불' }],
              memo: '마트 장보기'
            },
            {
              id: 'tx-4',
              date: `${currentMonth}-04`,
              debits: [{ accountId: 'x2', amount: 65000, tag: '지하철' }],
              credits: [{ accountId: 'a1', amount: 65000, tag: '이체' }],
              memo: '교통카드 충전'
            },
            {
              id: 'tx-5',
              date: `${currentMonth}-05`,
              debits: [{ accountId: 'a1', amount: 2500000, tag: '이체' }],
              credits: [{ accountId: 'r1', amount: 2500000, tag: '기본급' }],
              memo: '월급 입금'
            },
            {
              id: 'tx-6',
              date: `${lastMonth}-01`,
              debits: [{ accountId: 'x3', amount: 500000, tag: '월세' }],
              credits: [{ accountId: 'a1', amount: 500000, tag: '이체' }],
              memo: '지난달 월세 납부'
            },
            {
              id: 'tx-7',
              date: `${lastMonth}-15`,
              debits: [{ accountId: 'x1', amount: 250000, tag: '외식' }],
              credits: [{ accountId: 'l1', amount: 250000, tag: '일시불' }],
              memo: '외식비 통합 지출'
            }
          ],
          budgets: {
            [lastMonth]: {
              'x1': 200000,
              'x2': 50000,
              'x3': 500000,
              'other': 100000
            },
            [currentMonth]: {
              'x1': 250000,
              'x2': 70000,
              'x3': 500000,
              'other': 120000
            }
          }
        };
        setData(normalizeData(mockRes));
        setTimeout(() => setLoading(false), 500);
      }
    } catch (e) {
      if (retryCount < 2) setTimeout(() => loadData(retryCount + 1), 1000);
      else setError('데이터 로딩 실패');
    } finally {
      if(typeof google !== 'undefined') setLoading(false);
    }
  }, []);

  useEffect(() => { loadData(); }, [loadData]);

  const getAccountById = useCallback((id) => {
    if (id === 'closing_temp') return { id: 'closing_temp', name: '결산(임시)' };
    const found = flatAccounts.find(a => String(a.id) === String(id));
    return found || { id, name: id }; 
  }, [flatAccounts]);

  const runGasCommand = (cmd, ...args) => {
    return new Promise((resolve, reject) => {
      if (typeof google === 'undefined') { resolve({success: true}); return; }
      google.script.run.withSuccessHandler(res => {
        if(res) resolve(res); else reject("명령 실패");
      }).withFailureHandler(reject)[cmd](...args);
    });
  };

  const saveTransaction = async (tx) => {
    setData(prev => {
      const idx = prev.transactions.findIndex(t => t.id === tx.id);
      const newTxs = [...prev.transactions];
      if (idx >= 0) newTxs[idx] = tx; else newTxs.push(tx);
      return { ...prev, transactions: newTxs };
    });
    try { await runGasCommand('saveTransaction', tx); } 
    catch (e) { alert('거래 저장 실패: ' + e); loadData(); }
  };

  const deleteTransaction = async (id) => {
    setData(prev => ({ ...prev, transactions: prev.transactions.filter(t => t.id !== id) }));
    try { await runGasCommand('deleteTransaction', id); } 
    catch (e) { alert('거래 삭제 실패: ' + e); loadData(); }
  };

  const saveSettingsData = async (newInitialSetup, newAccounts) => {
    setData(prev => ({ ...prev, initialSetup: newInitialSetup, accounts: newAccounts }));
    try { await runGasCommand('saveSettings', { initialSetup: newInitialSetup, accounts: newAccounts }); } 
    catch (e) { alert('설정 저장 실패: ' + e); loadData(); }
  };

  const saveBudget = async (month, budgetData) => {
    setData(prev => ({ ...prev, budgets: { ...prev.budgets, [month]: budgetData } }));
    try { await runGasCommand('saveBudget', month, budgetData); }
    catch (e) { alert('예산 저장 실패: ' + e); loadData(); }
  };

  return { data, setData, loading, error, getAccountById, saveTransaction, deleteTransaction, saveSettingsData, saveBudget, flatAccounts, reload: loadData, runGasCommand };
};

