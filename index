  const formatCompact = (amount) => {
    const absAmt = Math.abs(amount);
    if (absAmt === 0) return '0';
    if (absAmt >= 10000) {
      const val = absAmt / 10000;
      return `${val.toFixed(1).replace(/\.0$/, '')}만`;
    } else if (absAmt >= 1000) {
      const val = absAmt / 1000;
      return `${val.toFixed(1).replace(/\.0$/, '')}천`;
    }
    return String(absAmt);
  };

