          <div className="bg-slate-50 dark:bg-[#1e293b] p-4 rounded-xl border border-slate-100 dark:border-slate-800 flex items-center justify-between">
            <span className="font-extrabold text-sm text-slate-600 dark:text-slate-400">총 예산 합계</span>
            <span className="font-mono font-black text-base sm:text-lg text-indigo-600 dark:text-indigo-400">${editTotal.toLocaleString()}원</span>
          </div>

          <div className="flex gap-3 justify-end pt-3">
            <${Button} variant="secondary" onClick=${() => setIsEditModalOpen(false)}>취소<//>
            <${Button} variant="primary" onClick=${handleSave}>저장<//>
          </div>
