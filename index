                              <button onClick=${() => handleRemoveTag(selectedAccountForTag.category, selectedAccountForTag.id, tag)} className="text-indigo-400 hover:text-red-500 transition-colors p-0.5">
                                <${XIcon} className="w-3 h-3 text-indigo-400 hover:text-red-500" />
                              </button>
                            </span>
                          `)}
                        </div>
                      </div>
                      
                      <div className="border-t border-slate-100 dark:border-slate-800 pt-4">
                        <div className="flex gap-2">
                          <input
                            id="new-tag-input"
                            type="text"
                            placeholder="새 태그 이름 입력 후 Enter (예: 외식, 배달)"
                            className="flex-1 p-2.5 rounded-xl border border-slate-200 dark:border-slate-800 text-xs font-bold text-slate-700 dark:text-slate-200 bg-white dark:bg-[#131b2e] outline-none focus:border-indigo-500 dark:focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 dark:focus:ring-indigo-950"
                            onKeyDown=${(e) => {
                              if (e.key === 'Enter') {
                                handleAddTag(selectedAccountForTag.category, selectedAccountForTag.id, e.target.value);
                                e.target.value = '';
                              }
                            }}
                          />
                          <button
                            onClick=${() => {
                              const input = document.getElementById('new-tag-input');
                              if (input && input.value.trim()) {
                                handleAddTag(selectedAccountForTag.category, selectedAccountForTag.id, input.value);
                                input.value = '';
                              }
                            }}
                            className="bg-indigo-600 hover:bg-indigo-700 text-white font-bold text-xs px-4 py-2.5 rounded-xl transition-all shadow-sm active:scale-95 shrink-0"
                          >
                            추가
                          </button>
                        </div>
                      </div>
                    ` : html`
                      <div className="flex flex-col items-center justify-center h-full text-slate-400 dark:text-slate-300 gap-2 py-20 flex-1">
                        <${TagIcon} className="w-8 h-8 text-slate-300 dark:text-slate-700" />
                        <p className="text-xs font-bold">왼쪽 목록에서 계정과목을 선택하여 태그를 관리하세요.</p>
                      </div>
                    `}
                  </div>
                </div>
              </div>
            `}

            ${settingsTab === 'editTransactions' && html`
              <div className="space-y-4 pb-10">
                <div className="flex items-center gap-2 mb-4 bg-white dark:bg-[#131b2e]/80 p-3 rounded-xl border border-slate-200/80 dark:border-slate-800 font-bold overflow-x-auto">
                  <i data-lucide="search" className="text-slate-400 w-4 h-4 shrink-0"></i>
                  <input type="date" className="bg-transparent outline-none font-bold text-[11px] cursor-pointer text-slate-700 dark:text-slate-200" value=${editRange.start} onChange=${(e)=>setEditRange({...editRange, start: e.target.value})}/><span className="text-slate-400 dark:text-slate-600">~</span><input type="date" className="bg-transparent outline-none font-bold text-[11px] cursor-pointer text-slate-700 dark:text-slate-200" value=${editRange.end} onChange=${(e)=>setEditRange({...editRange, end: e.target.value})}/>
                </div>
                <div className="space-y-2 max-h-[480px] overflow-y-auto pr-1.5 modal-scroll">
                  ${transactions.filter(t => t.date >= editRange.start && t.date <= editRange.end).sort((a,b) => b.date.localeCompare(a.date)).map(t => html`
                    <div key=${t.id} onClick=${()=>{setEditingTransaction(t); setEntryRows({date:t.date, debits:t.debits, credits:t.credits, memo:t.memo}); setIsEntryModalOpen(true);}} className="p-3.5 bg-white dark:bg-[#131b2e] border border-slate-200 dark:border-slate-800 rounded-xl flex justify-between cursor-pointer hover:border-indigo-500 dark:hover:border-indigo-500 transition-all shadow-sm active:bg-indigo-50/50 dark:active:bg-indigo-950/20">
                      <div><p className="text-[9px] font-black text-slate-400 dark:text-slate-500 uppercase font-outfit">${t.date}</p><p className="font-extrabold text-xs text-slate-700 dark:text-slate-200 mt-1">${t.memo || '거래 내역'}</p></div>
                      <div className="text-right flex flex-col justify-center"><div className="font-mono font-black text-slate-700 dark:text-slate-100 text-xs sm:text-base">${(t.debits.reduce((s,d)=>s+d.amount, 0)).toLocaleString()}원</div></div>
                    </div>
                  `)}
                </div>
              </div>
            `}
            ${isDirty && html`
              <div className="mt-6 md:hidden">
                <${Button} variant="primary" onClick=${handleSyncSettings} className="w-full bg-orange-500 hover:bg-orange-600 dark:bg-orange-600 dark:hover:bg-orange-700 animate-pulse border-none">설정 변경사항 저장하기<//>
              </div>
            `}
          </div>
        </div>
      <//>

      <!-- 전표 입력 모달 리디자인 -->
      <${Modal} isOpen=${isEntryModalOpen} onClose=${() => {setIsEntryModalOpen(false); setEditingTransaction(null);}} title=${editingTransaction?"전표 수정":"전표 입력"} maxWidth="max-w-6xl" zIndex="z-[120]">
        <div className="flex flex-col lg:flex-row gap-4 sm:gap-6 text-slate-800 dark:text-slate-200">
          
          <!-- 모달 좌측 날짜 설정 사이드바 -->
          <div className="w-full lg:w-48 shrink-0 bg-slate-50 dark:bg-[#1e293b] p-4 rounded-2xl border border-slate-200/80 dark:border-slate-800 h-fit shadow-inner space-y-4">
            <!-- 모드 선택 버튼 (신규 입력 시에만 노출) -->
            ${!editingTransaction && html`
              <div className="flex lg:flex-col gap-2 border-b border-slate-100 dark:border-slate-800 pb-3.5 mb-1.5 shrink-0">
                <button 
                  onClick=${() => setEntryMode('normal')}
                  className=${`flex-1 py-2 px-3 rounded-xl font-bold text-xs transition-all text-center ${entryMode === 'normal' ? 'bg-indigo-600 text-white shadow-sm' : 'bg-white dark:bg-[#131b2e] text-slate-500 dark:text-slate-400 border border-slate-200 dark:border-slate-800 hover:bg-slate-100 dark:hover:bg-slate-800'}`}
                >
                  일반 입력
                </button>
                <button 
                  onClick=${() => setEntryMode('continuous')}
                  className=${`flex-1 py-2 px-3 rounded-xl font-bold text-xs transition-all text-center ${entryMode === 'continuous' ? 'bg-indigo-600 text-white shadow-sm' : 'bg-white dark:bg-[#131b2e] text-slate-500 dark:text-slate-400 border border-slate-200 dark:border-slate-800 hover:bg-slate-100 dark:hover:bg-slate-800'}`}
                >
                  연속 입력
                </button>
              </div>
            `}

            ${(editingTransaction || entryMode === 'normal') ? html`
              <div>
                <label className="block text-[9px] font-black text-slate-500 dark:text-slate-300 mb-2 text-center lg:text-left font-outfit tracking-wider">전표 날짜</label>
                <input type="date" className="w-full p-2.5 rounded-xl border border-slate-200 dark:border-slate-800 text-xs font-bold outline-none mb-3 shadow-sm bg-white dark:bg-[#131b2e] text-slate-700 dark:text-slate-200" value=${entryRows.date} onChange=${(e) => setEntryRows({...entryRows, date: e.target.value})} />
              </div>
            ` : html`
              <div className="space-y-3.5">
                <div>
                  <label className="block text-[9px] font-black text-slate-500 dark:text-slate-300 mb-1.5 font-outfit tracking-wider">시작 월</label>
                  <input type="month" className="w-full p-2.5 rounded-xl border border-slate-300 dark:border-slate-800 text-xs font-bold outline-none shadow-sm bg-white dark:bg-[#131b2e] text-slate-700 dark:text-slate-200" value=${startMonth} onChange=${(e) => setStartMonth(e.target.value)} />
                </div>
                <div>
                  <label className="block text-[9px] font-black text-slate-500 dark:text-slate-300 mb-1.5 font-outfit tracking-wider">종료 월</label>
                  <input type="month" className="w-full p-2.5 rounded-xl border border-slate-300 dark:border-slate-800 text-xs font-bold outline-none shadow-sm bg-white dark:bg-[#131b2e] text-slate-700 dark:text-slate-200" value=${endMonth} onChange=${(e) => setEndMonth(e.target.value)} />
                </div>
                <div>
                  <label className="block text-[9px] font-black text-slate-500 dark:text-slate-300 mb-1.5 font-outfit tracking-wider">매월 반복 일자 (1~31)</label>
                  <input type="number" min="1" max="31" className="w-full p-2.5 rounded-xl border border-slate-300 dark:border-slate-800 text-xs font-bold outline-none shadow-sm bg-white dark:bg-[#131b2e] text-slate-700 dark:text-slate-200" value=${repeatDay} onChange=${(e) => setRepeatDay(Math.min(31, Math.max(1, Number(e.target.value) || 1)))} />
                </div>
              </div>
            `}

            ${editingTransaction && html`<button onClick=${handleDeleteTransactionWrapper} className="w-full p-3 bg-red-50 dark:bg-red-500/10 text-red-500 dark:text-red-400 rounded-xl font-bold text-[11px] hover:bg-red-500 hover:text-white dark:hover:bg-red-500 dark:hover:text-white transition-all shadow-sm flex items-center justify-center gap-2"><i data-lucide="trash-2" className="w-3.5 h-3.5"></i>삭제하기</button>`}
          </div>
          
          <div className="flex-1 space-y-4 pb-20 sm:pb-0">
            <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
              
              <!-- 차변 입력 패널 -->
              <div className="bg-white dark:bg-[#131b2e]/85 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm flex flex-col overflow-hidden">
                <div className="bg-indigo-600 text-white p-2.5 font-black text-center text-[10px] uppercase tracking-wider font-outfit border-b border-indigo-600/30">Debit (차변)</div>
                <div className="p-3.5 space-y-2.5 min-h-[120px] sm:min-h-[250px] flex-1">
                  ${entryRows.debits.map((r, i) => {
                    const account = r.accountId ? getAccountById(r.accountId) : null;
                    const availableTags = [...(account?.tags || [])];
                    if (r.tag && !availableTags.includes(r.tag)) availableTags.push(r.tag);
                    return html`
                      <div key=${i} className="flex gap-1.5 items-center animate-in slide-in-from-left-2">
                        <button onClick=${() => setActivePicker({ type: 'debits', index: i })} className="flex-1 min-w-[70px] p-2.5 rounded-lg bg-slate-50 dark:bg-[#1e293b] text-[11px] font-bold border border-slate-100 dark:border-slate-800 text-slate-700 dark:text-slate-200 text-left truncate active:bg-indigo-50/50">${account ? account.name : '계정 선택'}</button>
                        <select 
                          value=${r.tag || ''} 
                          onChange=${(e) => handleUpdateEntryRow('debits', i, 'tag', e.target.value)}
                          disabled=${!r.accountId}
                          className="w-24 sm:w-28 p-2 rounded-lg bg-white dark:bg-[#131b2e] border border-slate-200 dark:border-slate-800 text-xs font-bold outline-none text-slate-700 dark:text-slate-200 disabled:opacity-40"
                        >
                          <option value="">태그 없음</option>
                          ${availableTags.map(t => html`<option key=${t} value=${t}>${t}</option>`)}
                        </select>
                        <input type="number" className="w-20 sm:w-24 p-2 rounded-lg bg-white dark:bg-[#131b2e] text-right font-black border border-slate-200 dark:border-slate-800 text-xs outline-none font-mono text-slate-800 dark:text-slate-100" placeholder="0" value=${r.amount || ''} onChange=${(e) => handleUpdateEntryRow('debits', i, 'amount', Number(e.target.value))} />
                        <button onClick=${()=>{const n=[...entryRows.debits]; if(n.length>1){n.splice(i,1); setEntryRows(prev => ({...prev, debits:n}));}}} className="text-slate-400 dark:text-slate-300 hover:text-red-500 dark:hover:text-red-400 p-1"><${TrashIcon}/></button>
                      </div>
                    `;
                  })}
                  <button onClick=${() => setEntryRows(prev => ({...prev, debits: [...prev.debits, {accountId:'', amount:0, tag:''}]}))} className="w-full p-2.5 mt-1 text-[10px] font-black text-indigo-500 dark:text-indigo-400 border border-dashed border-indigo-200 dark:border-indigo-800/80 rounded-xl hover:bg-indigo-50/40 dark:hover:bg-indigo-950/20 transition-all flex items-center justify-center gap-2">+ 행 추가</button>
                </div>
                <div className="bg-slate-50 dark:bg-[#0f1524] p-2.5 sm:p-3.5 flex justify-between items-center font-black border-t border-slate-100 dark:border-slate-800 text-xs sm:text-base">
                  <span className="text-[9px] uppercase text-slate-400 dark:text-slate-300 font-outfit">Total Debit</span>
                  ${totalCreditSum > totalDebitSum && html`
                    <span className="text-[10px] sm:text-xs text-red-500 font-black px-2 py-0.5 rounded-md bg-red-50/80 dark:bg-red-950/20 border border-red-100/50 dark:border-red-900/30 animate-pulse">
                      ${(totalCreditSum - totalDebitSum).toLocaleString()}원 부족
                    </span>
                  `}
                  <span className="font-mono text-indigo-600 dark:text-indigo-400 font-black">${totalDebitSum.toLocaleString()}원</span>
                </div>
              </div>

              <!-- 대변 입력 패널 -->
              <div className="bg-white dark:bg-[#131b2e]/85 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm flex flex-col overflow-hidden">
                <div className="bg-red-500 text-white p-2.5 font-black text-center text-[10px] uppercase tracking-wider font-outfit border-b border-red-400/30">Credit (대변)</div>
                <div className="p-3.5 space-y-2.5 min-h-[120px] sm:min-h-[250px] flex-1">
                  ${entryRows.credits.map((r, i) => {
                    const account = r.accountId ? getAccountById(r.accountId) : null;
                    const availableTags = [...(account?.tags || [])];
                    if (r.tag && !availableTags.includes(r.tag)) availableTags.push(r.tag);
                    return html`
                      <div key=${i} className="flex gap-1.5 items-center animate-in slide-in-from-right-2">
                        <button onClick=${() => setActivePicker({ type: 'credits', index: i })} className="flex-1 min-w-[70px] p-2.5 rounded-lg bg-slate-50 dark:bg-[#1e293b] text-[11px] font-bold border border-slate-100 dark:border-slate-800 text-slate-700 dark:text-slate-200 text-left truncate active:bg-red-50/50">${account ? account.name : '계정 선택'}</button>
                        <select 
                          value=${r.tag || ''} 
                          onChange=${(e) => handleUpdateEntryRow('credits', i, 'tag', e.target.value)}
                          disabled=${!r.accountId}
                          className="w-24 sm:w-28 p-2 rounded-lg bg-white dark:bg-[#131b2e] border border-slate-200 dark:border-slate-800 text-xs font-bold outline-none text-slate-700 dark:text-slate-200 disabled:opacity-40"
                        >
                          <option value="">태그 없음</option>
                          ${availableTags.map(t => html`<option key=${t} value=${t}>${t}</option>`)}
                        </select>
                        <input type="number" className="w-20 sm:w-24 p-2 rounded-lg bg-white dark:bg-[#131b2e] text-right font-black border border-slate-200 dark:border-slate-800 text-xs outline-none font-mono text-slate-800 dark:text-slate-100" placeholder="0" value=${r.amount || ''} onChange=${(e) => handleUpdateEntryRow('credits', i, 'amount', Number(e.target.value))} />
                        <button onClick=${()=>{const n=[...entryRows.credits]; if(n.length>1){n.splice(i,1); setEntryRows(prev => ({...prev, credits:n}));}}} className="text-slate-400 dark:text-slate-300 hover:text-red-500 dark:hover:text-red-400 p-1"><${TrashIcon}/></button>
                      </div>
                    `;
                  })}
                  <button onClick=${() => setEntryRows(prev => ({...prev, credits: [...prev.credits, {accountId:'', amount:0, tag:''}]}))} className="w-full p-2.5 mt-1 text-[10px] font-black text-red-500 dark:text-red-400 border border-dashed border-red-200 dark:border-slate-800/80 rounded-xl hover:bg-red-50/40 dark:hover:bg-red-950/20 transition-all flex items-center justify-center gap-2">+ 행 추가</button>
                </div>
                <div className="bg-slate-50 dark:bg-[#0f1524] p-2.5 sm:p-3.5 flex justify-between items-center font-black border-t border-slate-100 dark:border-slate-800 text-xs sm:text-base">
                  <span className="text-[9px] uppercase text-slate-400 dark:text-slate-300 font-outfit">Total Credit</span>
                  ${totalDebitSum > totalCreditSum && html`
                    <span className="text-[10px] sm:text-xs text-red-500 font-black px-2 py-0.5 rounded-md bg-red-50/80 dark:bg-red-950/20 border border-red-100/50 dark:border-red-900/30 animate-pulse">
                      ${(totalDebitSum - totalCreditSum).toLocaleString()}원 부족
                    </span>
                  `}
                  <span className="font-mono text-red-500 dark:text-rose-400 font-black">${totalCreditSum.toLocaleString()}원</span>
                </div>
              </div>
            </div>
            
            <!-- 메모 입력 및 전송 영역 -->
            <div className="bg-slate-50 dark:bg-[#1e293b]/60 p-3 sm:p-4.5 rounded-2xl border border-slate-200/80 dark:border-slate-800/80 flex flex-col gap-3 shadow-inner">
              <input type="text" className="w-full bg-white dark:bg-[#131b2e] p-3 rounded-xl border border-slate-200 dark:border-slate-800 outline-none font-bold placeholder:text-slate-300 dark:placeholder:text-slate-500 text-slate-800 dark:text-slate-100 text-xs sm:text-base focus:ring-2 focus:ring-indigo-100 dark:focus:ring-indigo-950" placeholder="거래 메모를 입력하세요 (예: 마트 식재료 지출)" value=${entryRows.memo} onChange=${(e) => setEntryRows({...entryRows, memo: e.target.value})} />
              <div className="flex items-center justify-between gap-4">
                <span className=${`px-4 py-2.5 rounded-full text-[10px] font-black uppercase shadow-sm ${totalDebitSum === totalCreditSum && totalDebitSum > 0 ? 'bg-emerald-500 text-white' : 'bg-slate-200 dark:bg-slate-800 text-slate-500 dark:text-slate-400'}`}>
                  ${totalDebitSum === totalCreditSum && totalDebitSum > 0 
                    ? '차대일치 (Balanced)' 
                    : `차대불일치 (${Math.abs(totalDebitSum - totalCreditSum).toLocaleString()}원 차이)`}
                </span>
                <button onClick=${handleSaveEntry} disabled=${isSavingEntry || totalDebitSum !== totalCreditSum || totalDebitSum === 0} className="flex-1 bg-gradient-to-r from-indigo-500 to-violet-600 disabled:from-slate-300 disabled:to-slate-300 dark:disabled:from-slate-800 dark:disabled:to-slate-800 text-white disabled:text-slate-500 dark:disabled:text-slate-500 px-6 py-3.5 rounded-xl font-black shadow-lg hover:shadow-indigo-500/20 transition-all active:scale-95 text-xs sm:text-sm whitespace-nowrap">
                  ${isSavingEntry ? html`
                    <span className="flex items-center justify-center gap-2">
                      <i data-lucide="loader-2" className="w-4 h-4 animate-spin"></i> 저장 중...
                    </span>
                  ` : "전표 저장하기"}
                </button>
              </div>
            </div>
          </div>
        </div>
      <//>

      <!-- 계정과목 하위 피커 모달 -->
      <${Modal} isOpen=${activePicker !== null} onClose=${() => setActivePicker(null)} title="계정과목 선택" maxWidth="max-w-4xl" zIndex="z-[150]">
        <${AccountGridPicker} accounts=${accounts} onPick=${handleAccountPick} />
      <//>
    </div>
  `;
};

const Root = () => html`
  <${ErrorBoundary}>
    <${App} />
  <//>
`;

const root = ReactDOM.createRoot(document.getElementById('root'));
root.render(html`<${Root} />`);
</script>
</body>
</html>
