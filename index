<head>
<meta charset="UTF-8">
<script>
  (function() {
    var logError = function(message, source, lineno, colno, error) {
      var errDiv = document.getElementById('debug-error-box');
      if (!errDiv) {
        errDiv = document.createElement('div');
        errDiv.id = 'debug-error-box';
        errDiv.style.position = 'fixed';
        errDiv.style.top = '0';
        errDiv.style.left = '0';
        errDiv.style.width = '100%';
        errDiv.style.height = '100%';
        errDiv.style.backgroundColor = '#fee2e2';
        errDiv.style.color = '#991b1b';
        errDiv.style.padding = '24px';
        errDiv.style.fontFamily = 'monospace';
        errDiv.style.zIndex = '99999';
        errDiv.style.overflow = 'auto';
        document.body.appendChild(errDiv);
      }
      errDiv.innerHTML = '<h1 style="font-size: 20px; font-weight: bold; margin-bottom: 16px;">Error Detected</h1>' +
        '<p style="font-weight: bold; margin-bottom: 8px;">' + message + '</p>' +
        (source ? '<p style="margin-bottom: 8px;">Source: ' + source + ' | Line: ' + lineno + '</p>' : '') +
        (error && error.stack ? '<pre style="background: white; padding: 16px; border-radius: 8px; border: 1px solid #fca5a5; overflow: auto; max-height: 70vh;">' + error.stack + '</pre>' : '');
    };

    window.onerror = function(message, source, lineno, colno, error) {
      logError(message, source, lineno, colno, error);
      return false;
    };

    var originalConsoleError = console.error;
    console.error = function() {
      originalConsoleError.apply(console, arguments);
      var args = Array.prototype.slice.call(arguments);
      var msg = args.map(function(arg) {
        return typeof arg === 'object' ? JSON.stringify(arg) : String(arg);
      }).join(' ');
      logError('Console Error: ' + msg);
    };
  })();
</script>
