                <div className="flex flex-wrap gap-1.5 items-center">
                  <span className="text-[10px] text-slate-500 dark:text-slate-500 mr-1 uppercase tracking-wider font-outfit">소분류 집계:</span>
                  ${sortedTags.map(item => html`
                    <span key=${item.tag} className="bg-indigo-50 dark:bg-indigo-500/10 border border-indigo-100/50 dark:border-indigo-500/20 text-indigo-600 dark:text-indigo-400 px-2.5 py-1 rounded-lg text-[9px] font-extrabold shadow-sm">
                      #${item.tag} <span className="font-mono text-[9px] text-indigo-500 dark:text-indigo-300 font-extrabold">${item.amount.toLocaleString()}원</span>
                    </span>
                  `)}
                  ${noTagTotal !== 0 && html`
                    <span className="bg-slate-100 dark:bg-slate-800 border border-slate-200/60 dark:border-slate-700/60 text-slate-500 dark:text-slate-400 px-2.5 py-1 rounded-lg text-[9px] font-extrabold shadow-sm">
                      태그 미지정 <span className="font-mono text-[9px] text-slate-400 dark:text-slate-300 font-extrabold">${noTagTotal.toLocaleString()}원</span>
                    </span>
                  `}
                  ${sortedTags.length === 0 && noTagTotal === 0 && html`
                    <span className="text-slate-400 dark:text-slate-500 text-[10px] font-bold">집계할 데이터가 없습니다.</span>
                  `}
                </div>
                <div className="text-[10px] sm:text-xs font-black text-slate-700 dark:text-slate-200 bg-white dark:bg-[#131b2e] border border-slate-200 dark:border-slate-800 px-3 py-1 rounded-lg shadow-sm">
                  총액: <span className="font-mono text-indigo-600 dark:text-indigo-400">${data.total.toLocaleString()}원</span>
                </div>
              </div>
              <div className="p-3">
                <table className="w-full text-left table-fixed">
                  <thead className="text-slate-400 dark:text-slate-500 text-[9px] sm:text-[10px] font-black uppercase tracking-widest border-b border-slate-100 dark:border-slate-800 bg-slate-50/50 dark:bg-[#0f1524]/30 font-outfit">
                    <tr>
                      <th className="py-2 px-1.5 sm:px-3 rounded-tl-lg w-24 sm:w-32 whitespace-nowrap">날짜</th>
                      <th className="py-2 px-1.5 sm:px-3">거래내용</th>
                      <th className="py-2 px-1.5 sm:px-3 text-right rounded-tr-lg w-24 sm:w-32 whitespace-nowrap">금액</th>
                    </tr>
                  </thead>
                  <tbody className="divide-y divide-slate-50 dark:divide-slate-850">
                    ${data.lines.map((line, idx) => html`
                      <tr key=${idx} onClick=${() => line.txId && onEditTransaction && onEditTransaction(line.txId)} className=${`transition-colors ${line.txId && onEditTransaction ? 'cursor-pointer hover:bg-indigo-50/50 dark:hover:bg-indigo-950/20 active:bg-indigo-100/50' : 'hover:bg-slate-50/50 dark:hover:bg-slate-800/10'}`}>
                        <td className="py-2.5 px-1.5 sm:px-3 text-slate-500 dark:text-slate-400 font-mono text-[10px] sm:text-xs whitespace-nowrap truncate">${line.date}</td>
                        <td className="py-2.5 px-1.5 sm:px-3 text-slate-700 dark:text-slate-200 font-bold text-[10px] sm:text-sm leading-tight" style=${{ wordBreak: 'keep-all', overflowWrap: 'break-word' }}>
                          ${line.memo || '내역 없음'}
                          ${line.tag && html`<br /><span className="text-[9px] sm:text-xs text-slate-500 dark:text-slate-500 font-normal">#${line.tag}</span>`}
                        </td>
                        <td className="py-2.5 px-1.5 sm:px-3 text-right font-mono font-black text-slate-800 dark:text-slate-100 text-[11px] sm:text-sm whitespace-nowrap">${line.amount.toLocaleString()}원</td>
                      </tr>
                    `)}
                  </tbody>
                </table>
              </div>
            </div>
          `;
        })()}
      </div>
    `;
  };

  return html`
    <div className="max-w-4xl mx-auto space-y-6 animate-in fade-in duration-300 pb-10">
      <${Card} className="p-4 sm:p-5 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <h2 className="text-lg sm:text-xl font-black text-slate-800 dark:text-slate-100 flex items-center gap-2">
          <i data-lucide=${reportType === 'revenue' ? 'trending-up' : 'receipt'} className=${reportType === 'revenue' ? 'text-emerald-500' : 'text-orange-500'}></i> 월간손익명세
        </h2>
        <div className="flex items-center gap-3 self-end sm:self-auto">
          <div className="bg-slate-100 dark:bg-slate-900 p-1 rounded-xl flex gap-1 border border-slate-200/80 dark:border-slate-800/85">
            <button 
              onClick=${() => { setReportType('revenue'); setExpandedAccounts({}); }} 
              className=${`px-3 py-1.5 rounded-lg text-xs font-black transition-all ${reportType === 'revenue' ? 'bg-white dark:bg-[#1d263b] text-emerald-600 dark:text-emerald-400 shadow-sm' : 'text-slate-500 dark:text-slate-400 hover:text-slate-800 dark:hover:text-white'}`}
            >
              수익
            </button>
            <button 
              onClick=${() => { setReportType('expenses'); setExpandedAccounts({}); }} 
