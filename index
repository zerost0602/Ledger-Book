              <div className="flex items-center gap-2 p-3 bg-indigo-50/40 dark:bg-indigo-950/20 border border-indigo-100/50 dark:border-indigo-900/30 rounded-xl">
                <span className="flex-1 font-black text-xs sm:text-sm text-indigo-700 dark:text-indigo-400">기타비용 (예산 미지정 항목 공통 예산)</span>
                <div className="relative w-40 sm:w-48">
                  <input
                    type="number"
                    className="w-full p-3 pr-8 rounded-xl border border-indigo-200 dark:border-indigo-900/40 outline-none focus:border-indigo-500 dark:focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 dark:focus:ring-indigo-950/40 transition-all text-xs sm:text-sm font-black text-indigo-700 dark:text-indigo-400 bg-white dark:bg-[#131b2e] text-right font-mono"
                    placeholder="0"
                    value=${editOtherAmount || ''}
