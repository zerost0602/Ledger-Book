const MonthlyBudgetReport = ({ accounts, transactions, budgets = {}, saveBudget }) => {
  const [targetMonth, setTargetMonth] = useState(new Date().toISOString().slice(0, 7));
  const [isEditModalOpen, setIsEditModalOpen] = useState(false);
  const [editRows, setEditRows] = useState([]);
  const [editOtherAmount, setEditOtherAmount] = useState(0);
  const [activeBudgetPicker, setActiveBudgetPicker] = useState(null); // null or { index }
  const [isOtherExpanded, setIsOtherExpanded] = useState(false);

  // Get active budget for the target month
  const activeBudget = useMemo(() => {
    if (budgets[targetMonth]) {
      return budgets[targetMonth];
    }
    // Carry over from the latest month available
    const keys = Object.keys(budgets).sort();
    const prevKeys = keys.filter(k => k < targetMonth);
    if (prevKeys.length > 0) {
      return budgets[prevKeys[prevKeys.length - 1]];
    }
    return {};
  }, [budgets, targetMonth]);

  // Calculate spent for each expense account in targetMonth
  const spentMap = useMemo(() => {
    const monthlyTx = transactions.filter(t => {
      const isClosingTx = (t.id && String(t.id).startsWith('CLOSE-')) || (t.memo && t.memo.includes('[결산'));
      return t.date.startsWith(targetMonth) && !isClosingTx;
    });

    const map = {};
    accounts.expenses.forEach(acc => {
      map[acc.id] = 0;
    });

    monthlyTx.forEach(tx => {
      (tx.debits || []).forEach(d => {
        if (map[d.accountId] !== undefined) {
          map[d.accountId] += d.amount;
        }
      });
      (tx.credits || []).forEach(c => {
        if (map[c.accountId] !== undefined) {
          map[c.accountId] -= c.amount;
        }
      });
    });

    return map;
  }, [transactions, targetMonth, accounts.expenses]);

  // Separate budgeted and unbudgeted expense accounts
  const budgetDataList = useMemo(() => {
    const budgeted = [];
    const unbudgeted = [];
    let otherSpent = 0;

    accounts.expenses.forEach(acc => {
      const budgetAmount = activeBudget[acc.id] || 0;
      const spentAmount = spentMap[acc.id] || 0;
      const remainingAmount = budgetAmount - spentAmount;

      if (budgetAmount > 0) {
        budgeted.push({
          id: acc.id,
          name: acc.name,
          budget: budgetAmount,
          spent: spentAmount,
          remaining: remainingAmount
        });
      } else {
        unbudgeted.push({
          id: acc.id,
          name: acc.name,
          budget: 0,
          spent: spentAmount,
          remaining: -spentAmount
        });
        otherSpent += spentAmount;
      }
    });

    // Other Expenses
    const otherBudget = activeBudget['other'] || 0;
    const otherRemaining = otherBudget - otherSpent;

    return {
      budgeted: budgeted.sort((a, b) => b.budget - a.budget),
      unbudgeted: unbudgeted.filter(a => a.spent !== 0).sort((a, b) => b.spent - a.spent),
      other: {
        budget: otherBudget,
        spent: otherSpent,
        remaining: otherRemaining
      }
    };
  }, [accounts.expenses, activeBudget, spentMap]);

  const totalBudget = useMemo(() => {
    const budgetedSum = budgetDataList.budgeted.reduce((s, a) => s + a.budget, 0);
    return budgetedSum + budgetDataList.other.budget;
  }, [budgetDataList]);

  const totalSpent = useMemo(() => {
    return accounts.expenses.reduce((s, acc) => s + (spentMap[acc.id] || 0), 0);
  }, [accounts.expenses, spentMap]);

  const totalRemaining = totalBudget - totalSpent;

  // Edit Modal handlers
  const openEditModal = () => {
    const initialRows = [];
    Object.keys(activeBudget).forEach(key => {
      if (key !== 'other' && activeBudget[key] > 0) {
        initialRows.push({
          accountId: key,
          amount: activeBudget[key]
        });
      }
    });
    setEditRows(initialRows);
    setEditOtherAmount(activeBudget['other'] || 0);
    setIsEditModalOpen(true);
  };

  const handleSave = async () => {
    const cleanedBudget = {};
    if (editOtherAmount > 0) {
      cleanedBudget['other'] = Number(editOtherAmount) || 0;
    }
    editRows.forEach(row => {
      if (row.accountId && Number(row.amount) > 0) {
        cleanedBudget[row.accountId] = Number(row.amount) || 0;
      }
    });
    await saveBudget(targetMonth, cleanedBudget);
    setIsEditModalOpen(false);
  };

  const handleRowAmountChange = (index, val) => {
    setEditRows(prev => {
      const next = [...prev];
      next[index] = { ...next[index], amount: Number(val) || 0 };
      return next;
    });
  };

  const handleAddRow = () => {
    setEditRows(prev => [...prev, { accountId: '', amount: 0 }]);
  };

  const handleRemoveRow = (index) => {
    setEditRows(prev => prev.filter((_, i) => i !== index));
  };

  const handleBudgetAccountPick = (id) => {
    if (activeBudgetPicker === null) return;
    const { index } = activeBudgetPicker;
    setEditRows(prev => {
      const next = [...prev];
      next[index] = { ...next[index], accountId: id };
      return next;
    });
    setActiveBudgetPicker(null);
  };

  const getAccountName = (id) => {
    const found = accounts.expenses.find(a => String(a.id) === String(id));
    return found ? found.name : '계정 선택';
  };

  const editTotal = useMemo(() => {
    const rowsSum = editRows.reduce((s, r) => s + (Number(r.amount) || 0), 0);
    return rowsSum + (Number(editOtherAmount) || 0);
  }, [editRows, editOtherAmount]);

  useEffect(() => {
    if (window.lucide) window.lucide.createIcons();
  }, [targetMonth, isEditModalOpen, editRows, activeBudgetPicker]);

  return html`
    <div className="max-w-4xl mx-auto space-y-6 animate-in fade-in duration-300 pb-10 text-slate-800">
      <div className="bg-white p-4 sm:p-5 rounded-2xl shadow-sm border border-slate-200 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <h2 className="text-lg sm:text-xl font-black text-slate-800 flex items-center gap-2">
          <i data-lucide="piggy-bank" className="text-indigo-600"></i> 월별 예산 관리
        </h2>
        <div className="flex items-center gap-3 self-end sm:self-auto">
          <${Button} variant="primary" onClick=${openEditModal} className="text-xs font-bold py-1.5 px-3">
            <i data-lucide="edit" className="w-4 h-4"></i> 예산 수정
          <//>
          <div className="flex items-center gap-2 bg-slate-50 px-3 py-1.5 rounded-xl border border-slate-200 font-bold">
            <i data-lucide="calendar" className="w-4 h-4 text-slate-400"></i>
            <input type="month" value=${targetMonth} onChange=${(e) => setTargetMonth(e.target.value)} className="bg-transparent font-bold text-slate-700 border-none outline-none text-sm cursor-pointer" />
          </div>
        </div>
      </div>

      <div className="bg-white p-5 rounded-2xl shadow-sm border border-slate-200 space-y-4">
        <div className="flex justify-between items-center mb-4 border-b pb-2">
