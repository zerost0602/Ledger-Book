      <//>

      <${Modal} isOpen=${activeBudgetPicker !== null} onClose=${() => setActiveBudgetPicker(null)} title="예산 설정 계정과목 선택" maxWidth="max-w-4xl" zIndex="z-[160]">
        <${AccountGridPicker} accounts=${accounts} onPick=${handleBudgetAccountPick} allowedCategories=${['expenses']} />
      <//>
    </div>`;
};

// --- 메인 App 컴포넌트 ---
const App = () => {
  const { data, setData, loading, error, getAccountById, saveTransaction, deleteTransaction, saveSettingsData, saveBudget, flatAccounts, reload, runGasCommand } = useAccounting();
  
  // 테마 모드 상태 정의 (React State 및 LocalStorage 연동)
  const [isDarkMode, setIsDarkMode] = useState(() => {
    if (typeof google === 'undefined') {
      const saved = localStorage.getItem('darkMode');
      if (saved !== null) return JSON.parse(saved);
      return window.matchMedia('(prefers-color-scheme: dark)').matches;
    }
    return false; // GAS 환경 내 기본 라이트
  });

  const toggleDarkMode = () => {
    setIsDarkMode(prev => {
      const next = !prev;
      localStorage.setItem('darkMode', JSON.stringify(next));
      return next;
    });
  };

  // 다크모드 HTML 클래스 제어
  useEffect(() => {
    if (isDarkMode) {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
  }, [isDarkMode]);

  const [isDirty, setIsDirty] = useState(false);
  const [currentView, setCurrentView] = useState('CALENDAR');
  const [isSidebarOpen, setIsSidebarOpen] = useState(window.innerWidth > 1024);
  const [isSettingsModalOpen, setIsSettingsModalOpen] = useState(false);
  const [settingsTab, setSettingsTab] = useState('equity');
  const [isEntryModalOpen, setIsEntryModalOpen] = useState(false);
  const [editingTransaction, setEditingTransaction] = useState(null);

  const [statusMessage, setStatusMessage] = useState(null);
  const [confirmDialog, setConfirmDialog] = useState(null);
  const [activePicker, setActivePicker] = useState(null);

  const [standardDate, setStandardDate] = useState(new Date().toISOString().split('T')[0]);
  const [editRange, setEditRange] = useState({
    start: new Date(new Date().getFullYear(), new Date().getMonth(), 1).toISOString().split('T')[0],
    end: new Date().toISOString().split('T')[0]
  });

  const [entryRows, setEntryRows] = useState({
    date: new Date().toISOString().split('T')[0],
    debits: [{ accountId: '', amount: 0 }],
    credits: [{ accountId: '', amount: 0 }],
    memo: ''
  });

  const [entryMode, setEntryMode] = useState('normal'); // 'normal' | 'continuous'
  const [startMonth, setStartMonth] = useState(new Date().toISOString().slice(0, 7));
  const [endMonth, setEndMonth] = useState(new Date().toISOString().slice(0, 7));
  const [repeatDay, setRepeatDay] = useState(new Date().getDate());

  const [addingToCategory, setAddingToCategory] = useState(null);
  const [draggedAccountId, setDraggedAccountId] = useState(null);
  const [searchTerm, setSearchTerm] = useState('');
  const [searchDateRange, setSearchDateRange] = useState({ start: '', end: '' });
  const [isSavingEntry, setIsSavingEntry] = useState(false);

  const [selectedAccountForTag, setSelectedAccountForTag] = useState(null);
  const [isAccountListOpen, setIsAccountListOpen] = useState(true);

  const handleAddTag = (category, accountId, tagText) => {
    const text = tagText.trim();
    if (!text) return;
    setData(prev => {
      const newAccounts = { ...prev.accounts };
      newAccounts[category] = newAccounts[category].map(a => {
        if (String(a.id) === String(accountId)) {
          const tags = a.tags || [];
          if (tags.includes(text)) return a;
          return { ...a, tags: [...tags, text] };
        }
        return a;
      });
      return { ...prev, accounts: newAccounts };
    });
    setIsDirty(true);
  };

  const handleRemoveTag = (category, accountId, tagText) => {
    setData(prev => {
      const newAccounts = { ...prev.accounts };
      newAccounts[category] = newAccounts[category].map(a => {
        if (String(a.id) === String(accountId)) {
          const tags = a.tags || [];
          return { ...a, tags: tags.filter(t => t !== tagText) };
        }
        return a;
      });
      return { ...prev, accounts: newAccounts };
    });
    setIsDirty(true);
  };

  useEffect(() => { if (statusMessage) { const t = setTimeout(() => setStatusMessage(null), 3000); return () => clearTimeout(t); } }, [statusMessage]);
  useEffect(() => { setTimeout(() => { if(window.lucide) window.lucide.createIcons(); }, 50); });

  useEffect(() => {
    const handleVisibilityChange = async () => {
      if (document.visibilityState === 'visible') {
        if (typeof google === 'undefined') return;
        const timeoutPromise = new Promise((_, reject) =>
          setTimeout(() => reject(new Error('Ping Timeout')), 3000)
        );
        const pingPromise = new Promise((resolve, reject) => {
          google.script.run
            .withSuccessHandler(resolve)
            .withFailureHandler(reject)
            .ping();
        });
        try {
          await Promise.race([pingPromise, timeoutPromise]);
          console.log('GAS Connection health check: OK');
        } catch (e) {
          console.warn('GAS Connection health check failed. Reloading...', e);
          window.location.reload();
        }
      }
    };
    document.addEventListener('visibilitychange', handleVisibilityChange);
    return () => {
      document.removeEventListener('visibilitychange', handleVisibilityChange);
    };
  }, []);

  const initialSetup = data.initialSetup;
  const accounts = data.accounts;
  const transactions = data.transactions;

  const setupTotalDebits = useMemo(() => (initialSetup.debits || []).reduce((s, d) => s + Number(d.amount || 0), 0), [initialSetup.debits]);
  const setupTotalOtherCredits = useMemo(() => (initialSetup.credits || []).reduce((s, c) => s + Number(c.amount || 0), 0), [initialSetup.credits]);
  const calculatedInitialCapital = useMemo(() => setupTotalDebits - setupTotalOtherCredits, [setupTotalDebits, setupTotalOtherCredits]);

  const yearStartDate = useMemo(() => `${standardDate.split('-')[0]}-01-01`, [standardDate]);
  const allBsTransactions = useMemo(() => transactions.filter(t => t.date <= standardDate), [transactions, standardDate]);
  const performanceTransactions = useMemo(() => transactions.filter(t => t.date >= yearStartDate && t.date <= standardDate), [transactions, yearStartDate, standardDate]);

  const accountBalances = useMemo(() => {
    const balances = {};
    flatAccounts.forEach(a => balances[a.id] = 0);
    balances['closing_temp'] = 0;
    (initialSetup.debits || []).forEach(d => { if (d.accountId) { balances[d.accountId] = (balances[d.accountId] || 0) + Number(d.amount || 0); } });
    (initialSetup.credits || []).forEach(c => { if (c.accountId) { balances[c.accountId] = (balances[c.accountId] || 0) - Number(c.amount || 0); } });
    allBsTransactions.forEach(t => {
      t.debits.forEach(d => { balances[d.accountId] = (balances[d.accountId] || 0) + Number(d.amount || 0); });
      t.credits.forEach(c => { balances[c.accountId] = (balances[c.accountId] || 0) - Number(c.amount || 0); });
    });
    return balances;
  }, [allBsTransactions, accounts, initialSetup, flatAccounts]);

  const revenueHierarchy = useMemo(() => {
    const subtypes = ['fixed', 'variable'];
    const groups = subtypes.map(st => {
      const accs = accounts.revenue.filter(a => (a.subtype || 'fixed') === st).map(acc => {
        let amt = 0;
        performanceTransactions.forEach(t => { t.credits.forEach(c => { if(c.accountId === acc.id) amt += Number(c.amount); }); t.debits.forEach(d => { if(d.accountId === acc.id) amt -= Number(d.amount); }); });
        return { name: acc.name, amount: amt };
      }).filter(a => a.amount !== 0);
      return { label: st === 'fixed' ? '고정 항목' : '변동 항목', subtotal: accs.reduce((s, a) => s + a.amount, 0), accounts: accs };
    });
    return { total: groups.reduce((s, g) => s + g.subtotal, 0), groups };
  }, [performanceTransactions, accounts]);

  const expensesHierarchy = useMemo(() => {
    const subtypes = ['fixed', 'variable'];
    const groups = subtypes.map(st => {
      const accs = accounts.expenses.filter(a => (a.subtype || 'fixed') === st).map(acc => {
        let amt = 0;
        performanceTransactions.forEach(t => { t.debits.forEach(d => { if(d.accountId === acc.id) amt += Number(d.amount); }); t.credits.forEach(c => { if(c.accountId === acc.id) amt -= Number(c.amount); }); });
        return { name: acc.name, amount: amt };
      }).filter(a => a.amount !== 0);
      return { label: st === 'fixed' ? '고정 항목' : '변동 항목', subtotal: accs.reduce((s, a) => s + a.amount, 0), accounts: accs };
    });
    return { total: groups.reduce((s, g) => s + g.subtotal, 0), groups };
  }, [performanceTransactions, accounts]);

  const reportNetIncome = useMemo(() => revenueHierarchy.total - expensesHierarchy.total, [revenueHierarchy, expensesHierarchy]);

  const unsettledNetIncome = useMemo(() => {
    const revBal = accounts.revenue.reduce((sum, acc) => {
        const bal = accountBalances[acc.id] || 0;
        return sum + (bal < 0 ? Math.abs(bal) : -bal);
    }, 0);
    const expBal = accounts.expenses.reduce((sum, acc) => {
        const bal = accountBalances[acc.id] || 0;
        return sum + (bal > 0 ? bal : -Math.abs(bal));
    }, 0);
    return revBal - expBal;
  }, [accountBalances, accounts]);

  const totalAssets = accounts.assets.reduce((sum, acc) => sum + (accountBalances[acc.id] || 0), 0);
  const totalLiabilitiesOnly = accounts.liabilities.filter(a => a.name !== '이익잉여금').reduce((sum, acc) => sum + Math.abs(accountBalances[acc.id] || 0), 0);
  
  const retainedEarningsAcc = flatAccounts.find(a => a.name === '이익잉여금');
  const retainedEarningsId = retainedEarningsAcc ? retainedEarningsAcc.id : 'e1';
  const retainedEarningsBalance = Math.abs(accountBalances[retainedEarningsId] || 0);
  const retainedEarningsRow = useMemo(() => (initialSetup.credits || []).find(c => String(c.accountId) === String(retainedEarningsId)), [initialSetup.credits, retainedEarningsId]);
  const retainedEarningsAmount = retainedEarningsRow ? retainedEarningsRow.amount : 0;
  const currentEquity = calculatedInitialCapital + (accountBalances[retainedEarningsId] < 0 ? Math.abs(accountBalances[retainedEarningsId]) : -accountBalances[retainedEarningsId]) + unsettledNetIncome;

  const totalDebitSum = useMemo(() => (entryRows.debits || []).reduce((s, r) => s + Number(r.amount || 0), 0), [entryRows.debits]);
  const totalCreditSum = useMemo(() => (entryRows.credits || []).reduce((s, r) => s + Number(r.amount || 0), 0), [entryRows.credits]);

  const handleSyncSettings = async () => {
    await saveSettingsData(initialSetup, accounts);
    setIsDirty(false); setStatusMessage({ type: 'success', text: '설정 저장 완료' });
  };

  const handleAddAccount = (category, name) => {
    if (!name.trim()) return;
    setData(prev => {
      const newArr = [...prev.accounts[category], { id: Date.now().toString(), name: name.trim(), subtype: 'fixed' }];
      newArr.sort((a, b) => a.name.localeCompare(b.name, 'ko-KR'));
      return { ...prev, accounts: { ...prev.accounts, [category]: newArr } };
    });
    setIsDirty(true); setAddingToCategory(null);
  };

  const handleUpdateAccountName = (category, id, name) => {
    setData(prev => {
      const newArr = prev.accounts[category].map(a => String(a.id) === String(id) ? { ...a, name: name.trim() } : a);
      newArr.sort((a, b) => a.name.localeCompare(b.name, 'ko-KR'));
      return { ...prev, accounts: { ...prev.accounts, [category]: newArr } };
    });
    setIsDirty(true);
  };

  const handleDeleteAccount = (category, id) => {
    setConfirmDialog({
      title: '삭제 확인', message: '해당 계정과목을 삭제하시겠습니까?',
      onConfirm: () => {
        setData(prev => ({ ...prev, accounts: { ...prev.accounts, [category]: prev.accounts[category].filter(a => String(a.id) !== String(id)) } }));
        setIsDirty(true); setConfirmDialog(null);
      }
    });
  };

  const handleDeleteTransactionWrapper = () => {
    if (!editingTransaction) return;
    setConfirmDialog({
      title: '전표 삭제', message: '이 거래를 삭제하시겠습니까?',
      onConfirm: async () => {
        await deleteTransaction(editingTransaction.id);
        setIsEntryModalOpen(false); setEditingTransaction(null); setConfirmDialog(null);
      }
    });
  };

  const handleSaveEntry = async () => {
    if (totalDebitSum !== totalCreditSum || totalDebitSum === 0) return;
    setIsSavingEntry(true);
    try {
      if (!editingTransaction && entryMode === 'continuous') {
        // 연속/반복 입력 모드
        if (startMonth > endMonth) {
          alert("시작 월은 종료 월보다 이전이어야 합니다.");
          setIsSavingEntry(false);
          return;
        }

        const txs = [];
        let currentDate = new Date(startMonth + '-01');
        const endDate = new Date(endMonth + '-01');
        const ts = Date.now();
        let idx = 0;

        while (currentDate <= endDate) {
          const yr = currentDate.getFullYear();
          const mth = currentDate.getMonth();
          const lastDay = new Date(yr, mth + 1, 0).getDate();
          const targetDay = Math.min(repeatDay, lastDay);
          const dateStr = `${yr}-${String(mth + 1).padStart(2, '0')}-${String(targetDay).padStart(2, '0')}`;

          txs.push({
            id: `T-${ts}-${idx}`,
            date: dateStr,
            debits: entryRows.debits.filter(d => d.accountId && d.amount > 0).map(d => ({ accountId: d.accountId, amount: d.amount, tag: d.tag || '' })),
            credits: entryRows.credits.filter(c => c.accountId && c.amount > 0).map(c => ({ accountId: c.accountId, amount: c.amount, tag: c.tag || '' })),
            memo: entryRows.memo || '거래 내역'
          });

          currentDate.setMonth(currentDate.getMonth() + 1);
          idx++;
        }

        // 로컬 상태 대량 업데이트
        setData(prev => ({
          ...prev,
          transactions: [...prev.transactions, ...txs]
        }));

        // 백엔드(GAS) 저장
        await Promise.all(txs.map(tx => runGasCommand('saveTransaction', tx)));
      } else {
        // 일반 입력 또는 수정 모드
        const newTransaction = {
          id: editingTransaction ? editingTransaction.id : `T-${Date.now()}`,
          date: entryRows.date,
          debits: entryRows.debits.filter(d => d.accountId && d.amount > 0).map(d => ({ accountId: d.accountId, amount: d.amount, tag: d.tag || '' })),
          credits: entryRows.credits.filter(c => c.accountId && c.amount > 0).map(c => ({ accountId: c.accountId, amount: c.amount, tag: c.tag || '' })),
          memo: entryRows.memo || '거래 내역'
        };
        await saveTransaction(newTransaction);
      }
      setIsEntryModalOpen(false); setEditingTransaction(null);
      setEntryRows({ date: new Date().toISOString().split('T')[0], debits: [{ accountId: '', amount: 0, tag: '' }], credits: [{ accountId: '', amount: 0, tag: '' }], memo: '' });
    } catch (e) {
      alert("거래 저장 실패: " + e);
      reload();
    } finally {
      setIsSavingEntry(false);
    }
  };

  const handleClosing = () => {
    const closingDebits = [];
    const closingCredits = [];
    let totalRevToClear = 0;
    let totalExpToClear = 0;

    accounts.revenue.forEach(acc => {
      const bal = accountBalances[acc.id] || 0;
      if (bal !== 0) {
        if (bal < 0) {
          const amt = Math.abs(bal);
          closingDebits.push({ accountId: acc.id, amount: amt });
          totalRevToClear += amt;
        } else {
          const amt = bal;
          closingCredits.push({ accountId: acc.id, amount: amt });
          totalRevToClear -= amt;
        }
      }
    });

    accounts.expenses.forEach(acc => {
      const bal = accountBalances[acc.id] || 0;
      if (bal !== 0) {
        if (bal > 0) {
          const amt = bal;
          closingCredits.push({ accountId: acc.id, amount: amt });
          totalExpToClear += amt;
        } else {
          const amt = Math.abs(bal);
          closingDebits.push({ accountId: acc.id, amount: amt });
          totalExpToClear -= amt;
        }
      }
    });

    if (totalRevToClear === 0 && totalExpToClear === 0) {
      setStatusMessage({ type: 'error', text: '결산할 잔액이 없습니다.' });
      return;
    }

    const netIncome = totalRevToClear - totalExpToClear;

    setConfirmDialog({
      title: '장부 결산 실행',
      message: `${standardDate} 기준으로 수익과 비용의 모든 잔액을 정리하시겠습니까? (순이익 ${netIncome.toLocaleString()}원)`,
      onConfirm: async () => {
        const ts = Date.now();
        const entry1_debits = [...closingDebits];
        const entry1_credits = [...closingCredits];
        if (netIncome > 0) { entry1_credits.push({ accountId: 'closing_temp', amount: netIncome }); } 
        else if (netIncome < 0) { entry1_debits.push({ accountId: 'closing_temp', amount: Math.abs(netIncome) }); }

        const entry1 = { id: `CLOSE-A-${ts}`, date: standardDate, debits: entry1_debits, credits: entry1_credits, memo: `[결산-1] ${standardDate} 수익비용 잔액 집계` };

        const entry2_debits = [];
        const entry2_credits = [];
        if (netIncome > 0) {
          entry2_debits.push({ accountId: 'closing_temp', amount: netIncome });
          entry2_credits.push({ accountId: retainedEarningsId, amount: netIncome });
        } else if (netIncome < 0) {
          const loss = Math.abs(netIncome);
          entry2_debits.push({ accountId: retainedEarningsId, amount: loss });
          entry2_credits.push({ accountId: 'closing_temp', amount: loss });
        }

        await saveTransaction(entry1);
        if (netIncome !== 0) {
          await saveTransaction({ id: `CLOSE-B-${ts}`, date: standardDate, debits: entry2_debits, credits: entry2_credits, memo: `[결산-2] ${standardDate} 순이익 이익잉여금 대체` });
        }
        setConfirmDialog(null); setStatusMessage({ type: 'success', text: '결산이 완료되었습니다.' });
      }
    });
  };

  const handleUpdateEntryRow = (type, index, field, value) => {
    setEntryRows(prev => {
      const newRows = [...prev[type]];
      newRows[index] = { ...newRows[index], [field]: value };
      return { ...prev, [type]: newRows };
    });
  };

  const handleAccountPick = (id) => {
    if (!activePicker) return;
    const { type, index } = activePicker;
    if (type === 'setupDebits') setData(prev => { const n = [...prev.initialSetup.debits]; n[index].accountId = id; return { ...prev, initialSetup: { ...prev.initialSetup, debits: n } }; });
    else if (type === 'setupCredits') setData(prev => { const n = [...prev.initialSetup.credits]; n[index].accountId = id; return { ...prev, initialSetup: { ...prev.initialSetup, credits: n } }; });
    else {
      setEntryRows(prev => {
        const newRows = [...prev[type]];
        newRows[index] = { ...newRows[index], accountId: id, tag: '' };
        return { ...prev, [type]: newRows };
      });
    }
    setActivePicker(null); setIsDirty(true);
  };

  const handleDragOver = (e) => e.preventDefault();
  const handleAccountDragStart = (id) => setDraggedAccountId(id);
  const handleSubtypeDrop = (subtype, type) => {
    if (!draggedAccountId) return;
    setData(prev => ({ ...prev, accounts: { ...prev.accounts, [type]: prev.accounts[type].map(a => String(a.id) === String(draggedAccountId) ? { ...a, subtype } : a) } }));
    setIsDirty(true); setDraggedAccountId(null);
  };

  const filteredTxs = useMemo(() => {
    if (!searchTerm && !searchDateRange.start && !searchDateRange.end) return [];
    const term = searchTerm.toLowerCase();
    return transactions.filter(t => {
      if (searchDateRange.start && t.date < searchDateRange.start) return false;
      if (searchDateRange.end && t.date > searchDateRange.end) return false;
      if (!term) return true;
      if (t.memo && t.memo.toLowerCase().includes(term)) return true;
      if (t.date.includes(term)) return true;
      const dMatch = t.debits.some(d => (getAccountById(d.accountId)?.name.toLowerCase().includes(term)) || (d.tag && d.tag.toLowerCase().includes(term)));
