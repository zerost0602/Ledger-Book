    { key: 'revenue', label: '수익', color: 'bg-emerald-50/80 text-emerald-700 border-emerald-100 dark:bg-emerald-950/20 dark:text-emerald-400 dark:border-emerald-900/30 hover:bg-emerald-100/50 dark:hover:bg-emerald-950/40' },
    { key: 'expenses', label: '비용', color: 'bg-orange-50/80 text-orange-700 border-orange-100 dark:bg-amber-950/20 dark:text-amber-400 dark:border-amber-900/30 hover:bg-orange-100/50 dark:hover:bg-amber-950/40' }
