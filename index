// --- 월간 손익 명세 컴포넌트 ---
const MonthlyIncomeExpenseReport = ({ accounts, transactions, getAccountById, onEditTransaction }) => {
  const [targetMonth, setTargetMonth] = useState(new Date().toISOString().slice(0, 7));
  const [reportType, setReportType] = useState('expenses'); // 'expenses' | 'revenue'
  const [expandedAccounts, setExpandedAccounts] = useState({});

  const revenueAccountIds = useMemo(() => accounts?.revenue?.map(r => r.id) || [], [accounts]);
  const expenseAccountIds = useMemo(() => accounts?.expenses?.map(e => e.id) || [], [accounts]);

  const targetAccountIds = useMemo(() => {
    return reportType === 'revenue' ? revenueAccountIds : expenseAccountIds;
  }, [reportType, revenueAccountIds, expenseAccountIds]);

  const reportData = useMemo(() => {
    const monthlyTx = transactions.filter(t => {
      const isClosingTx = (t.id && String(t.id).startsWith('CLOSE-')) || (t.memo && t.memo.includes('[결산'));
      return t.date.startsWith(targetMonth) && !isClosingTx;
    });
    
    let map = {};
    let totalVal = 0;

    targetAccountIds.forEach(accId => { map[accId] = { total: 0, lines: [] }; });

    monthlyTx.forEach(tx => {
      (tx.debits || []).forEach(d => {
        if (targetAccountIds.includes(d.accountId)) {
          if (!map[d.accountId]) map[d.accountId] = { total: 0, lines: [] };
          const amt = reportType === 'revenue' ? -d.amount : d.amount;
          map[d.accountId].lines.push({ txId: tx.id, date: tx.date, memo: tx.memo, amount: amt, tag: d.tag || '' });
          map[d.accountId].total += amt;
          totalVal += amt;
        }
      });
      (tx.credits || []).forEach(c => {
        if (targetAccountIds.includes(c.accountId)) {
          if (!map[c.accountId]) map[c.accountId] = { total: 0, lines: [] };
          const amt = reportType === 'revenue' ? c.amount : -c.amount;
          map[c.accountId].lines.push({ txId: tx.id, date: tx.date, memo: tx.memo, amount: amt, tag: c.tag || '' });
          map[c.accountId].total += amt;
          totalVal += amt;
        }
      });
    });

    const activeAccountIds = Object.keys(map)
      .filter(accId => map[accId].lines.length > 0)
      .sort((a, b) => {
        const accA = getAccountById(a);
        const accB = getAccountById(b);
        const subA = accA.subtype || 'variable';
        const subB = accB.subtype || 'variable';

        if (subA !== subB) {
          return subA === 'fixed' ? -1 : 1;
        }
        return map[b].total - map[a].total;
      });

    activeAccountIds.forEach(accId => {
      map[accId].lines.sort((a, b) => a.date.localeCompare(b.date));
    });

    let fixedTotal = 0;
    let variableTotal = 0;
    const fixedAccountIds = [];
    const variableAccountIds = [];

    activeAccountIds.forEach(accId => {
      const acc = getAccountById(accId);
      const sub = acc.subtype || 'variable';
      if (sub === 'fixed') {
        fixedAccountIds.push(accId);
        fixedTotal += map[accId].total;
      } else {
        variableAccountIds.push(accId);
        variableTotal += map[accId].total;
      }
    });

    return { map, activeAccountIds, fixedAccountIds, variableAccountIds, totalVal, fixedTotal, variableTotal };
  }, [transactions, targetMonth, targetAccountIds, reportType, getAccountById]);

  const toggleAccordion = (accountId) => {
    setExpandedAccounts(prev => ({ ...prev, [accountId]: !prev[accountId] }));
  };

  useEffect(() => {
    setTimeout(() => { if (window.lucide) window.lucide.createIcons(); }, 100);
  }, [targetMonth, reportType, expandedAccounts]);

  const renderAccountCard = (accountId) => {
    const isExpanded = !!expandedAccounts[accountId];
    const data = reportData.map[accountId];
    const account = getAccountById(accountId);
    const accountName = account.name;
    const subtype = account.subtype || 'variable';

    return html`
      <div key=${accountId} className="border border-slate-200 dark:border-slate-800 rounded-2xl overflow-hidden transition-all shadow-sm">
        <div onClick=${() => toggleAccordion(accountId)} className="flex justify-between items-center p-3.5 sm:p-4 bg-slate-50/50 hover:bg-slate-100/50 dark:bg-[#131b2e]/60 dark:hover:bg-[#17223b]/60 cursor-pointer transition select-none">
          <div className="font-extrabold text-slate-800 dark:text-slate-100 text-sm sm:text-base flex items-center gap-2">
            <span className=${`px-2 py-0.5 rounded-md text-[9px] font-black ${reportType === 'revenue' ? 'bg-emerald-100 text-emerald-600 dark:bg-emerald-500/10 dark:text-emerald-400' : 'bg-orange-100 text-orange-600 dark:bg-amber-500/10 dark:text-amber-400'}`}>
              ${reportType === 'revenue' ? '수익' : '비용'}
            </span>
            <span className=${`px-2 py-0.5 rounded-md text-[9px] font-black ${subtype === 'fixed' ? 'bg-blue-100 text-blue-700 dark:bg-blue-500/10 dark:text-blue-400' : 'bg-purple-100 text-purple-700 dark:bg-purple-500/10 dark:text-purple-400'}`}>
