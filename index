const MonthlyIncomeExpenseReport = ({ accounts, transactions, getAccountById, onEditTransaction }) => {
  const [targetMonth, setTargetMonth] = useState(new Date().toISOString().slice(0, 7));
  const [reportType, setReportType] = useState('expenses'); // 'expenses' | 'revenue'
  const [expandedAccounts, setExpandedAccounts] = useState({});

  const revenueAccountIds = useMemo(() => accounts?.revenue?.map(r => r.id) || [], [accounts]);
  const expenseAccountIds = useMemo(() => accounts?.expenses?.map(e => e.id) || [], [accounts]);

  const targetAccountIds = useMemo(() => {
    return reportType === 'revenue' ? revenueAccountIds : expenseAccountIds;
  }, [reportType, revenueAccountIds, expenseAccountIds]);

  const reportData = useMemo(() => {
    const monthlyTx = transactions.filter(t => {
      const isClosingTx = (t.id && String(t.id).startsWith('CLOSE-')) || (t.memo && t.memo.includes('[결산'));
      return t.date.startsWith(targetMonth) && !isClosingTx;
    });
    
    let map = {};
    let totalVal = 0;

    targetAccountIds.forEach(accId => { map[accId] = { total: 0, lines: [] }; });

    monthlyTx.forEach(tx => {
      (tx.debits || []).forEach(d => {
        if (targetAccountIds.includes(d.accountId)) {
          if (!map[d.accountId]) map[d.accountId] = { total: 0, lines: [] };
          const amt = reportType === 'revenue' ? -d.amount : d.amount;
          map[d.accountId].lines.push({ txId: tx.id, date: tx.date, memo: tx.memo, amount: amt });
          map[d.accountId].total += amt;
          totalVal += amt;
        }
      });
      (tx.credits || []).forEach(c => {
        if (targetAccountIds.includes(c.accountId)) {
          if (!map[c.accountId]) map[c.accountId] = { total: 0, lines: [] };
          const amt = reportType === 'revenue' ? c.amount : -c.amount;
          map[c.accountId].lines.push({ txId: tx.id, date: tx.date, memo: tx.memo, amount: amt });
          map[c.accountId].total += amt;
          totalVal += amt;
        }
      });
    });

    const activeAccountIds = Object.keys(map)
      .filter(accId => map[accId].lines.length > 0)
      .sort((a, b) => map[b].total - map[a].total);

    activeAccountIds.forEach(accId => {
      map[accId].lines.sort((a, b) => a.date.localeCompare(b.date));
    });

    return { map, activeAccountIds, totalVal };
  }, [transactions, targetMonth, targetAccountIds, reportType]);

  const toggleAccordion = (accountId) => {
    setExpandedAccounts(prev => ({ ...prev, [accountId]: !prev[accountId] }));
  };

  return html`
    <div className="max-w-4xl mx-auto space-y-6 animate-in fade-in duration-300 pb-10">
      <div className="bg-white p-4 sm:p-5 rounded-2xl shadow-sm border border-slate-200 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <h2 className="text-lg sm:text-xl font-black text-slate-800 flex items-center gap-2">
          <i data-lucide=${reportType === 'revenue' ? 'trending-up' : 'receipt'} className=${reportType === 'revenue' ? 'text-emerald-500' : 'text-orange-500'}></i> 월간손익명세
        </h2>
        <div className="flex items-center gap-3 self-end sm:self-auto">
          <div className="bg-slate-100 p-1 rounded-xl flex gap-1 border border-slate-200">
            <button 
              onClick=${() => { setReportType('revenue'); setExpandedAccounts({}); }} 
              className=${`px-3 py-1.5 rounded-lg text-xs font-black transition-all ${reportType === 'revenue' ? 'bg-white text-emerald-600 shadow-sm' : 'text-slate-500 hover:text-slate-800'}`}
            >
              수익
            </button>
            <button 
              onClick=${() => { setReportType('expenses'); setExpandedAccounts({}); }} 
              className=${`px-3 py-1.5 rounded-lg text-xs font-black transition-all ${reportType === 'expenses' ? 'bg-white text-orange-600 shadow-sm' : 'text-slate-500 hover:text-slate-800'}`}
            >
              비용
            </button>
          </div>
          <div className="flex items-center gap-2 bg-slate-50 px-3 py-1.5 rounded-xl border border-slate-200">
            <i data-lucide="calendar" className="w-4 h-4 text-slate-400"></i>
            <input type="month" value=${targetMonth} onChange=${(e) => setTargetMonth(e.target.value)} className="bg-transparent font-bold text-slate-700 border-none outline-none text-sm cursor-pointer" />
          </div>
        </div>
      </div>

      <div className="bg-white p-5 rounded-2xl shadow-sm border border-slate-200 space-y-4">
        <div className="flex justify-between items-center mb-4 border-b-2 pb-2 transition-all duration-300" style=${{ borderColor: reportType === 'revenue' ? '#10b981' : '#f97316' }}>
          <h3 className="text-sm sm:text-base font-bold text-slate-700 uppercase tracking-widest">
            ${reportType === 'revenue' ? '수익 계정과목별 상세내역' : '비용 계정과목별 상세내역'}
          </h3>
          <div className="text-right">
            <span className="text-[10px] font-black text-slate-400 uppercase mr-2">
              ${reportType === 'revenue' ? '총 수익액' : '총 지출액'}
            </span>
