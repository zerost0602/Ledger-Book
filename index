// --- 월별 예산 컴포넌트 ---
const MonthlyBudgetReport = ({ accounts, transactions, budgets = {}, saveBudget }) => {
  const [targetMonth, setTargetMonth] = useState(new Date().toISOString().slice(0, 7));
  const [isEditModalOpen, setIsEditModalOpen] = useState(false);
  const [editRows, setEditRows] = useState([]);
  const [editOtherAmount, setEditOtherAmount] = useState(0);
  const [activeBudgetPicker, setActiveBudgetPicker] = useState(null);
  const [isOtherExpanded, setIsOtherExpanded] = useState(false);

  const activeBudget = useMemo(() => {
    if (budgets[targetMonth]) return budgets[targetMonth];
    const keys = Object.keys(budgets).sort();
    const prevKeys = keys.filter(k => k < targetMonth);
    if (prevKeys.length > 0) return budgets[prevKeys[prevKeys.length - 1]];
    return {};
  }, [budgets, targetMonth]);

  const spentMap = useMemo(() => {
    const monthlyTx = transactions.filter(t => {
      const isClosingTx = (t.id && String(t.id).startsWith('CLOSE-')) || (t.memo && t.memo.includes('[결산'));
      return t.date.startsWith(targetMonth) && !isClosingTx;
    });

    const map = {};
    accounts.expenses.forEach(acc => { map[acc.id] = 0; });

    monthlyTx.forEach(tx => {
      (tx.debits || []).forEach(d => { if (map[d.accountId] !== undefined) map[d.accountId] += d.amount; });
      (tx.credits || []).forEach(c => { if (map[c.accountId] !== undefined) map[c.accountId] -= c.amount; });
    });
    return map;
  }, [transactions, targetMonth, accounts.expenses]);

  const budgetDataList = useMemo(() => {
    const budgeted = [];
    const unbudgeted = [];
    let otherSpent = 0;

    accounts.expenses.forEach(acc => {
      const budgetAmount = activeBudget[acc.id] || 0;
      const spentAmount = spentMap[acc.id] || 0;
      const remainingAmount = budgetAmount - spentAmount;

      if (budgetAmount > 0) {
        budgeted.push({
          id: acc.id,
          name: acc.name,
          budget: budgetAmount,
          spent: spentAmount,
          remaining: remainingAmount
        });
      } else {
        unbudgeted.push({
          id: acc.id,
          name: acc.name,
          budget: 0,
          spent: spentAmount,
          remaining: -spentAmount
        });
        otherSpent += spentAmount;
      }
    });

    const otherBudget = activeBudget['other'] || 0;
    const otherRemaining = otherBudget - otherSpent;

    return {
      budgeted: budgeted.sort((a, b) => b.budget - a.budget),
      unbudgeted: unbudgeted.filter(a => a.spent !== 0).sort((a, b) => b.spent - a.spent),
      other: { budget: otherBudget, spent: otherSpent, remaining: otherRemaining }
    };
  }, [accounts.expenses, activeBudget, spentMap]);

  const totalBudget = useMemo(() => {
    const budgetedSum = budgetDataList.budgeted.reduce((s, a) => s + a.budget, 0);
    return budgetedSum + budgetDataList.other.budget;
  }, [budgetDataList]);

  const totalSpent = useMemo(() => {
    return accounts.expenses.reduce((s, acc) => s + (spentMap[acc.id] || 0), 0);
  }, [accounts.expenses, spentMap]);

  const totalRemaining = totalBudget - totalSpent;

  const openEditModal = () => {
    const initialRows = [];
    Object.keys(activeBudget).forEach(key => {
      if (key !== 'other' && activeBudget[key] > 0) {
        initialRows.push({ accountId: key, amount: activeBudget[key] });
      }
    });
    setEditRows(initialRows);
    setEditOtherAmount(activeBudget['other'] || 0);
    setIsEditModalOpen(true);
  };

  const handleSave = async () => {
    const cleanedBudget = {};
    if (editOtherAmount > 0) cleanedBudget['other'] = Number(editOtherAmount) || 0;
    editRows.forEach(row => {
      if (row.accountId && Number(row.amount) > 0) {
        cleanedBudget[row.accountId] = Number(row.amount) || 0;
      }
    });
    await saveBudget(targetMonth, cleanedBudget);
    setIsEditModalOpen(false);
  };

  const handleRowAmountChange = (index, val) => {
    setEditRows(prev => {
      const next = [...prev];
      next[index] = { ...next[index], amount: Number(val) || 0 };
      return next;
    });
  };

  const handleAddRow = () => {
    setEditRows(prev => [...prev, { accountId: '', amount: 0 }]);
  };

  const handleRemoveRow = (index) => {
    setEditRows(prev => prev.filter((_, i) => i !== index));
  };

  const handleBudgetAccountPick = (id) => {
    if (activeBudgetPicker === null) return;
    const { index } = activeBudgetPicker;
    setEditRows(prev => {
      const next = [...prev];
      next[index] = { ...next[index], accountId: id };
      return next;
    });
    setActiveBudgetPicker(null);
