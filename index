            <div className="w-6 flex justify-end text-slate-400">
              ${isExpanded ? html`<i data-lucide="chevron-up" className="w-4 h-4"></i>` : html`<i data-lucide="chevron-down" className="w-4 h-4"></i>`}
            </div>
          </div>
        </div>

        ${isExpanded && (() => {
          const tagMap = {};
          let noTagTotal = 0;
          data.lines.forEach(line => {
