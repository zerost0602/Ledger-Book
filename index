                <div className=${`p-2 rounded-lg font-bold ${budgetDataList.other.remaining >= 0 ? 'bg-emerald-50 text-emerald-700' : 'bg-red-50 text-red-600'}`}>
                  <div className="text-[9px] font-black uppercase">${budgetDataList.other.remaining >= 0 ? '남은예산' : '예산초과'}</div>
                  <div className="font-mono font-black">${Math.abs(budgetDataList.other.remaining).toLocaleString()}원</div>
                </div>
              </div>

              ${isOtherExpanded && html`
                <div className="mt-4 pt-3 border-t border-slate-200 bg-white p-3 rounded-xl space-y-2 animate-in slide-in-from-top-2 duration-200">
                  <div className="text-[10px] font-black text-slate-400 uppercase tracking-wider mb-2">예산 미배정 계정별 지출액</div>
                  ${budgetDataList.unbudgeted.length === 0 ? html`
                    <p className="text-xs text-slate-400 italic text-center py-2">지출 내역이 없습니다.</p>
                  ` : html`
                    <div className="divide-y divide-slate-100">
                      ${budgetDataList.unbudgeted.map(item => html`
                        <div key=${item.id} className="flex justify-between py-2 text-xs">
                          <span className="text-slate-600 font-medium">${item.name}</span>
